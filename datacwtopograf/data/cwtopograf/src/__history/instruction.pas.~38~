unit instruction;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls, Vcl.ComCtrls, Vcl.Buttons,
  GDIPAPI, GDIPOBJ;

type
  // Переопределяем TSpeedButton, чтобы все кнопки в этом модуле рисовались
  // так же, как в главном меню (закруглённые края, рамка, выделение)
  TSpeedButton = class(Vcl.Buttons.TSpeedButton)
  protected
    procedure Paint; override;
  end;

  TFormInstruction = class(TForm)
    RichEdit1: TRichEdit;
    ButtonBack: TSpeedButton;
    procedure ButtonBackClick(Sender: TObject);
    procedure FormPaint(Sender: TObject);
    procedure FormShow(Sender: TObject);
    procedure RichEdit1Enter(Sender: TObject);
    procedure RichEdit1SelectionChange(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  FormInstruction: TFormInstruction;

implementation

{$R *.dfm}

{ TSpeedButton }

procedure TSpeedButton.Paint;
var
  graphics: TGPGraphics;
  path: TGPGraphicsPath;
  brush: TGPSolidBrush;
  pen, focusPen: TGPPen;
  rect: TGPRectF;
  radius: Single;
  textRect: TRectF;
  textColor: Cardinal;
  fontFamily: TGPFontFamily;
  font: TGPFont;
  format: TGPStringFormat;
begin
  inherited Paint; // очистка фона (стандартный фон закрашивается родителем)

  graphics := TGPGraphics.Create(Canvas.Handle);
  try
    graphics.SetSmoothingMode(SmoothingModeAntiAlias);
    graphics.SetPixelOffsetMode(PixelOffsetModeHighQuality);

    radius := 20; // радиус закругления

    // Основной путь для фона и рамки
    path := TGPGraphicsPath.Create;
    try
      rect.X := 0;
      rect.Y := 0;
      rect.Width := Width;
      rect.Height := Height;

      path.AddArc(rect.X, rect.Y, radius * 2, radius * 2, 180, 90);
      path.AddArc(rect.X + rect.Width - radius * 2, rect.Y, radius * 2, radius * 2, 270, 90);
      path.AddArc(rect.X + rect.Width - radius * 2, rect.Y + rect.Height - radius * 2, radius * 2, radius * 2, 0, 90);
      path.AddArc(rect.X, rect.Y + rect.Height - radius * 2, radius * 2, radius * 2, 90, 90);
      path.CloseFigure();

      // Заливка чёрным цветом
      brush := TGPSolidBrush.Create(MakeColor(255, 0, 0, 0));
      try
        graphics.FillPath(brush, path);
      finally
        brush.Free;
      end;

      // Рамка (золотая)
      pen := TGPPen.Create(MakeColor(255, 255, 215, 0), 2);
      try
        graphics.DrawPath(pen, path);
      finally
        pen.Free;
      end;

      // Если кнопка в фокусе – рисуем белую закруглённую рамку с отступом
      if Focused then
      begin
        focusPen := TGPPen.Create(MakeColor(255, 255, 255, 255), 1.5);
        rect.X := 3;
        rect.Y := 3;
        rect.Width := Width - 6;
        rect.Height := Height - 6;
        path.Reset;
        path.AddArc(rect.X, rect.Y, radius * 2, radius * 2, 180, 90);
        path.AddArc(rect.X + rect.Width - radius * 2, rect.Y, radius * 2, radius * 2, 270, 90);
        path.AddArc(rect.X + rect.Width - radius * 2, rect.Y + rect.Height - radius * 2, radius * 2, radius * 2, 0, 90);
        path.AddArc(rect.X, rect.Y + rect.Height - radius * 2, radius * 2, radius * 2, 90, 90);
        path.CloseFigure();
        graphics.DrawPath(focusPen, path);
        focusPen.Free;
      end;
    finally
      path.Free;
    end;

    // Текст кнопки (золотой, жирный)
    textRect.X := 0;
    textRect.Y := 0;
    textRect.Width := Width;
    textRect.Height := Height;

    fontFamily := TGPFontFamily.Create('Segoe UI');
    font := TGPFont.Create(fontFamily, Font.Size, FontStyleBold, UnitPoint);
    format := TGPStringFormat.Create;
    format.SetAlignment(StringAlignmentCenter);
    format.SetLineAlignment(StringAlignmentCenter);
    brush := TGPSolidBrush.Create(MakeColor(255, 255, 215, 0));
    try
      graphics.DrawString(Caption, -1, font, textRect, format, brush);
    finally
      brush.Free;
      font.Free;
      fontFamily.Free;
      format.Free;
    end;

  finally
    graphics.Free;
  end;
end;

procedure TFormInstruction.ButtonBackClick(Sender: TObject);
begin
  Self.Close;
end;

procedure TFormInstruction.FormPaint(Sender: TObject);
begin
  Canvas.Pen.Color := $00D7FF;
  Canvas.Pen.Width := 2;
  Canvas.Brush.Style := bsClear;
  Canvas.Rectangle(0, 0, ClientWidth, ClientHeight);
end;

procedure TFormInstruction.FormShow(Sender: TObject);
var
  FilePath: string;
begin
  RichEdit1.Clear;

  FilePath := ExpandFileName(ExtractFilePath(Application.ExeName) + '..\data\cwtopograf\assets\extras\guide.rtf');

  if FileExists(FilePath) then
  begin
    RichEdit1.PlainText := False;
    RichEdit1.Lines.LoadFromFile(FilePath);

    RichEdit1.SelectAll;
    RichEdit1.SelAttributes.Color := clWhite;
    RichEdit1.SelLength := 0;
  end
  else
  begin
    ShowMessage('Файл guide.rtf не найден :(');
  end;

  RichEdit1.SetFocus;
  HideCaret(RichEdit1.Handle);
  ActiveControl := nil;
end;

procedure TFormInstruction.RichEdit1Enter(Sender: TObject);
begin
  HideCaret(RichEdit1.Handle);
end;

procedure TFormInstruction.RichEdit1SelectionChange(Sender: TObject);
begin
  HideCaret(RichEdit1.Handle);
end;

end.
