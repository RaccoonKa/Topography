procedure TFormcoords25k.Image1MouseDown(Sender: TObject; Button: TMouseButton;
  Shift: TShiftState; X, Y: Integer);
begin
  ScrollingDownY := Y;
  ScrollingDownPositionY := ScrollBox1.VertScrollBar.Position;
  ScrollingDownX := X;
  ScrollingDownPositionX := ScrollBox1.HorzScrollBar.Position;
end;

procedure TFormcoords25k.Image1MouseMove(Sender: TObject; Shift: TShiftState; X, Y: Integer);
begin
  MouseX := x;
  MouseY := y;
  if (whatDraw <> '0') or FixL or (TaskStage = 3) then Lpaint;
  if ssLeft in Shift then
  begin
    ScrollBox1.VertScrollBar.Position := ScrollingDownPositionY + (ScrollingDownY - Y);
    ScrollingDownPositionY := ScrollBox1.VertScrollBar.Position;
    ScrollBox1.HorzScrollBar.Position := ScrollingDownPositionX + (ScrollingDownX - X);
    ScrollingDownPositionX := ScrollBox1.HorzScrollBar.Position;
    ScrollBox1.Update;
    Scrolling := True;
  end;
end;

procedure TFormcoords25k.Image1MouseUp(Sender: TObject; Button: TMouseButton;
  Shift: TShiftState; X, Y: Integer);
begin
  if not Scrolling then
  begin
    if whatDraw = 'L' then
    begin
      Image1.Cursor := crDefault;
      FixL := true;
      FixLx := Round(MouseX / zoom);
      FixLy := Round(MouseY / zoom);
      FixSpin := Spin;
      whatDraw := '0'
    end;
    if FixL and (Button = mbRight) then
    begin
      whatDraw := 'L';
      FixL := false;
      Lpaint;
    end;

    if (TaskStage = 3) and Tr then
    begin
      if (Button = mbLeft) and (not FixTr) then
      begin
        FixTr := True;
        FixTrX := MouseX;
        FixTrY := MouseY;
      end
      else if (Button = mbRight) and FixTr then
      begin
        FixTr := False;
        Lpaint;
      end;
    end;
  end
  else Scrolling := False;
end;

Procedure TFormcoords25k.LPaint;
var i: integer;
    CurGeoX, CurGeoY: Double;
    path: TGPGraphicsPath;
    solidBrush: TGPSolidBrush;
    fontFamily: TGPFontFamily;
    font: TGPFont;
    tipX, tipY: Integer;
begin
  T1 := now;
  graphicsGDIPlus := TGPGraphics.Create(Image1.Canvas.Handle);
  try
    GraphicsGDIPlus.SetInterpolationMode(InterpolationModeHighQualityBicubic);
    R.X := 0; R.Y := 0;
    R.Width := Round(2133 * zoom); R.Height := Round(2679 * zoom);
    graphicsGDIPlus.SetSmoothingMode(SmoothingModeAntiAlias);
    graphicsGDIPlus.DrawCachedBitmap(cBitMap, 0, 0);

    if whatDraw = 'Z1' then
      graphicsGDIPlus.DrawImage(znak1, MouseX - ZNAK1_OFFSET, MouseY - ZNAK1_OFFSET, ZNAK1_SIZE, ZNAK1_SIZE);
    if whatDraw = 'Z2' then
      graphicsGDIPlus.DrawImage(znak2, MouseX - 36, MouseY - 63, 75, 75);

    if FixZ = 'Z1' then
      graphicsGDIPlus.DrawImage(znak1, Round(FixFX * zoom) - ZNAK1_OFFSET, Round(FixFY * zoom) - ZNAK1_OFFSET, ZNAK1_SIZE, ZNAK1_SIZE);
    if FixZ = 'Z2' then
      graphicsGDIPlus.DrawImage(znak2, Round(FixFX * zoom) - 36, Round(FixFY * zoom) - 63, 75, 75);

    if TaskStage >= 2 then
    begin
      if TaskStage = 3 then
      begin
        tipX := Round(FixFX2 * zoom - 2);
        tipY := Round(FixFY2 * zoom + 12);
        graphicsGDIPlus.DrawLine(pen, Round(FixFX * zoom), Round(FixFY * zoom), tipX, tipY);
      end;

      if FixZ2 = 'Z1' then
        graphicsGDIPlus.DrawImage(znak1, Round(FixFX2 * zoom) - ZNAK1_OFFSET, Round(FixFY2 * zoom) - ZNAK1_OFFSET, ZNAK1_SIZE, ZNAK1_SIZE);
      if FixZ2 = 'Z2' then
        graphicsGDIPlus.DrawImage(znak2, Round(FixFX2 * zoom) - 36, Round(FixFY2 * zoom) - 63, 75, 75);
    end;

    if (TaskStage = 3) and Tr then
    begin
      if FixTr then
        graphicsGDIPlus.TranslateTransform(FixTrX, FixTrY)
      else
        graphicsGDIPlus.TranslateTransform(MouseX, MouseY);
      graphicsGDIPlus.RotateTransform(-spin);
      graphicsGDIPlus.DrawImage(Transportir, -250, -150);
      graphicsGDIPlus.ResetTransform;
    end;

    if fixL then
    begin
      graphicsGDIPlus.TranslateTransform(FixLX * zoom, FixLY * zoom);
      graphicsGDIPlus.ScaleTransform(zoom * Lzoom, zoom * Lzoom);
      graphicsGDIPlus.RotateTransform(-Fixspin);
      path := TGPGraphicsPath.Create;
      try
        solidBrush := TGPSolidBrush.Create(MakeColor(200, 255, 255, 255));
        try
          path.Reset;
          path.StartFigure();
          path.AddLine(-70, -40, 150, -40);
          path.AddLine(150, -40, -70, 100);
          path.AddLine(-70, 100, -70, -40);
          path.AddLine(-40, -10, 60, -10);
          path.AddLine(60, -10, -40, 50);
          path.AddLine(-40, 50, -40, -10);
          path.CloseFigure();
          graphicsGDIPlus.FillPath(solidBrush, path);

          graphicsGDIPlus.DrawLine(LinePen, -70, -40, 150, -40);
          graphicsGDIPlus.DrawLine(LinePen, 150, -40, -70, 100);
          graphicsGDIPlus.DrawLine(LinePen, -70, 100, -70, -40);
          graphicsGDIPlus.DrawLine(LinePen, -40, -10, 60, -10);
          graphicsGDIPlus.DrawLine(LinePen, 60, -10, -40, 50);
          graphicsGDIPlus.DrawLine(LinePen, -40, 50, -40, -10);
        finally
          solidBrush.Free;
        end;

        for i := 1 to 100 do
        begin
          if i mod 5 = 0 then
            graphicsGDIPlus.DrawLine(LinePen, i * 2 - 70, -40, i * 2 - 70, -33)
          else
            graphicsGDIPlus.DrawLine(LinePen, i * 2 - 70, -40, i * 2 - 70, -35);
        end;

        fontFamily := TGPFontFamily.Create('Times New Roman');
        font := TGPFont.Create(fontFamily, 9, FontStyleRegular, UnitPixel);
        solidBrush := TGPSolidBrush.Create(MakeColor(255, 0, 0, 0));
        try
          for i := 1 to 9 do
          begin
            graphicsGDIPlus.SetTextRenderingHint(TextRenderingHintAntiAlias);
            graphicsGDIPlus.DrawString(IntToStr(i), -1, font, MakePoint(i * 20 - 74, -33.0), solidBrush);
          end;
        finally
          fontFamily.Free;
          font.Free;
          solidBrush.Free;
        end;
      finally
        path.Free;
        graphicsGDIPlus.ResetTransform;
      end;
    end;

    if (whatDraw = 'L') then
    begin
      graphicsGDIPlus.TranslateTransform(MouseX, MouseY);
      graphicsGDIPlus.ScaleTransform(zoom * Lzoom, zoom * Lzoom);
      graphicsGDIPlus.RotateTransform(-spin);
      path := TGPGraphicsPath.Create;
      try
        solidBrush := TGPSolidBrush.Create(MakeColor(200, 255, 255, 255));
        try
          path.Reset;
          path.StartFigure();
          path.AddLine(-70, -40, 150, -40);
          path.AddLine(150, -40, -70, 100);
          path.AddLine(-70, 100, -70, -40);
          path.AddLine(-40, -10, 60, -10);
          path.AddLine(60, -10, -40, 50);
          path.AddLine(-40, 50, -40, -10);
          path.CloseFigure();
          graphicsGDIPlus.FillPath(solidBrush, path);

          graphicsGDIPlus.DrawLine(LinePen, -70, -40, 150, -40);
          graphicsGDIPlus.DrawLine(LinePen, 150, -40, -70, 100);
          graphicsGDIPlus.DrawLine(LinePen, -70, 100, -70, -40);
          graphicsGDIPlus.DrawLine(LinePen, -40, -10, 60, -10);
          graphicsGDIPlus.DrawLine(LinePen, 60, -10, -40, 50);
          graphicsGDIPlus.DrawLine(LinePen, -40, 50, -40, -10);
        finally
          solidBrush.Free;
        end;

        for i := 1 to 100 do
        begin
          if i mod 5 = 0 then
            graphicsGDIPlus.DrawLine(LinePen, i * 2 - 70, -40, i * 2 - 70, -33)
          else
            graphicsGDIPlus.DrawLine(LinePen, i * 2 - 70, -40, i * 2 - 70, -35);
        end;

        fontFamily := TGPFontFamily.Create('Times New Roman');
        font := TGPFont.Create(fontFamily, 9, FontStyleRegular, UnitPixel);
        solidBrush := TGPSolidBrush.Create(MakeColor(255, 0, 0, 0));
        try
          for i := 1 to 9 do
          begin
            graphicsGDIPlus.SetTextRenderingHint(TextRenderingHintAntiAlias);
            graphicsGDIPlus.DrawString(IntToStr(i), -1, font, MakePoint(i * 20 - 74, -33.0), solidBrush);
          end;
        finally
          fontFamily.Free;
          font.Free;
          solidBrush.Free;
        end;
      finally
        path.Free;
        graphicsGDIPlus.ResetTransform;
      end;
    end;

  finally
    graphicsGDIPlus.Free;
  end;

  Image1.Repaint;

  T2 := now;
  DecodeTime(T2 - T1, h, m, s, ms);
  PixelToGeo(MouseX / zoom, MouseY / zoom, CurGeoX, CurGeoY);
  Caption := Format('X: %.3f  Y: %.3f', [CurGeoX, CurGeoY]);
end;

procedure TFormcoords25k.LoadPoints(FileName: string);
var
  t: TextFile;
  s: string;
  parts: TStringList;
  fs: TFormatSettings;
begin
  if not FileExists(FileName) then Exit;
  fs := TFormatSettings.Create;
  fs.DecimalSeparator := '.';
  AssignFile(t, FileName);
  Reset(t);
  parts := TStringList.Create;
  parts.Delimiter := ';';
  try
    SetLength(Points, 0);
    while not Eof(t) do begin
      Readln(t, s);
      parts.DelimitedText := s;
      if parts.Count = 4 then begin
        SetLength(Points, Length(Points) + 1);
        Points[High(Points)].px := StrToFloat(parts[0], fs);
        Points[High(Points)].py := StrToFloat(parts[1], fs);
        Points[High(Points)].gx := StrToFloat(parts[2], fs);
        Points[High(Points)].gy := StrToFloat(parts[3], fs);
      end;
    end;
  finally
    parts.Free;
    CloseFile(t);
  end;
end;

procedure TFormcoords25k.PixelToGeo(px, py: Double; var GeoX, GeoY: Double);
var
  i, j: Integer;
  Dist: array of Double;
  Idx: array of Integer;
  tmpD: Double;
  tmpI: Integer;
  p1, p2, p3: Integer;
  x1, y1, x2, y2, x3, y3: Double;
  gx1, gy1, gx2, gy2, gx3, gy3: Double;
  det, L1, L2, L3: Double;
begin
  GeoX := 0; GeoY := 0;
  if Length(Points) < 3 then Exit;

  SetLength(Dist, Length(Points));
  SetLength(Idx, Length(Points));
  for i := 0 to High(Points) do
  begin
    Dist[i] := Sqrt(Sqr(px - Points[i].px) + Sqr(py - Points[i].py));
    Idx[i] := i;
  end;

  for i := 0 to High(Dist) - 1 do
    for j := i + 1 to High(Dist) do
      if Dist[j] < Dist[i] then
      begin
        tmpD := Dist[i]; Dist[i] := Dist[j]; Dist[j] := tmpD;
        tmpI := Idx[i]; Idx[i] := Idx[j]; Idx[j] := tmpI;
      end;

  p1 := Idx[0]; p2 := Idx[1]; p3 := -1;
  for i := 2 to High(Idx) do
  begin
    x1 := Points[p1].px; y1 := Points[p1].py;
    x2 := Points[p2].px; y2 := Points[p2].py;
    x3 := Points[Idx[i]].px; y3 := Points[Idx[i]].py;
    det := (y2 - y3) * (x1 - x3) + (x3 - x2) * (y1 - y3);
    if Abs(det) > 10.0 then begin p3 := Idx[i]; Break; end;
  end;
  if p3 = -1 then p3 := Idx[2];

  x1 := Points[p1].px; y1 := Points[p1].py; gx1 := Points[p1].gx; gy1 := Points[p1].gy;
  x2 := Points[p2].px; y2 := Points[p2].py; gx2 := Points[p2].gx; gy2 := Points[p2].gy;
  x3 := Points[p3].px; y3 := Points[p3].py; gx3 := Points[p3].gx; gy3 := Points[p3].gy;

  det := (y2 - y3) * (x1 - x3) + (x3 - x2) * (y1 - y3);
  if Abs(det) < 0.001 then Exit;

  L1 := ((y2 - y3) * (px - x3) + (x3 - x2) * (py - y3)) / det;
  L2 := ((y3 - y1) * (px - x3) + (x1 - x3) * (py - y3)) / det;
  L3 := 1.0 - L1 - L2;

  GeoX := L1 * gx1 + L2 * gx2 + L3 * gx3;
  GeoY := L1 * gy1 + L2 * gy2 + L3 * gy3;
end;

