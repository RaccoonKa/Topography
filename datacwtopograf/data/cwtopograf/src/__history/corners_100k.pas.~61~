  spin := 0;
  whatDraw := '0';
  MouseX := -1000;
  MouseY := -1000;

  Edit1.Clear; Edit2.Clear; Edit3.Clear; Edit4.Clear;
  Edit5.Clear; Edit9.Clear; Edit10.Clear; Edit11.Clear;

  if not Assigned(pen) then
  begin
    pen := TGPPen.Create(MakeColor(255, 255, 0, 0), 2);

    Bhide.Glyph.LoadFromFile('..\data\cwtopograf\assets\green\Bhide1.bmp');
    Bznak1.Glyph.LoadFromFile('..\data\cwtopograf\assets\green\Flag11.bmp');
    Panel1.Color := RGB(31, 21, 5);
    Panel3.Color := RGB(31, 21, 5);
    Image1.Cursor := crHandPoint;

    Image1.Width := Round(2043 * zoom);
    Image1.Height := Round(2566 * zoom);
    Image := TGPBitMap.Create('..\data\cwtopograf\assets\maps\map100k.jpg');

    WidthImage := Round(2043 * zoom);
    HightImage := Round(2566 * zoom);
    R.X := 0; R.Y := 0;
    R.Width := WidthImage; R.Height := HightImage;

    Bitmap := TGPBitmap.Create(WidthImage, HightImage);
    graphicsGDIPlus := TGPGraphics.Create(Bitmap);
    graphicsGDIPlus.SetInterpolationMode(InterpolationModeHighQualityBicubic);
    graphicsGDIPlus.DrawImage(Image, R);
    graphicsGDIPlus.Free;

    graphicsGDIPlus := TGPGraphics.Create(Image1.Canvas.Handle);
    cBitmap := TGPCachedBitmap.Create(Bitmap, graphicsGDIPlus);
    graphicsGDIPlus.DrawCachedBitmap(cBitmap, 0, 0);
    graphicsGDIPlus.Free;

    XFirst := 80; YFirst := 20;
    x1 := 214; y1 := 238;
    x2 := 685; y2 := 223;
    x3 := 699; y3 := 694;
    x4 := 228; y4 := 708;

    yy2 := (x2 - x1 + x3 - x4) / 16;
    yy1 := (y2 - y1 + y3 - y4) / 16;
    xx2 := (x4 - x1 + x3 - x2) / 16;
    xx1 := (y4 - y1 + y3 - y2) / 16;
    Det := xx1 * yy2 - xx2 * yy1;

    znak1 := TGPImage.Create('..\data\cwtopograf\assets\green\flag1.2.png');
    znak2 := TGPImage.Create('..\data\cwtopograf\assets\green\flag1.1.png');
    znak3 := TGPImage.Create('..\data\cwtopograf\assets\green\flag1.1.2.png');
    znak4 := TGPImage.Create('..\data\cwtopograf\assets\green\flag4.png');
    Transportir := TGPImage.Create('..\data\cwtopograf\assets\green\Transportir.png');

    ComboBox1.Items.LoadFromFile('..\data\cwtopograf\assets\extras\УвелУмен.txt');
    ComboBox2.Items.LoadFromFile('..\data\cwtopograf\assets\extras\Года.txt');
  end;

