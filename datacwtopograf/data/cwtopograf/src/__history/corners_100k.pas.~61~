procedure TFormcorners100k.FocusOnTask;
begin
  ScrollBox1.HorzScrollBar.Position := Round(FixFX2 * zoom) - (ScrollBox1.ClientWidth div 2);
  ScrollBox1.VertScrollBar.Position := Round(FixFY2 * zoom) - (ScrollBox1.ClientHeight div 2);
end;

procedure TFormcorners100k.GenerateRandomTask;
var
  Dist: Double;
const
  MinDist = 200;
begin
  FixFX := 250 + Random(1400);
  FixFY := 250 + Random(1700);
  repeat
    FixFX2 := 250 + Random(1400);
    FixFY2 := 250 + Random(1700);

    Dist := Hypot(FixFX2 - FixFX, FixFY2 - FixFY);

  until Dist > MinDist;

  if ComboBox1.Items.Count > 0 then
    ComboBox1.ItemIndex := Random(ComboBox1.Items.Count);

  if ComboBox2.Items.Count > 0 then
    ComboBox2.ItemIndex := Random(ComboBox2.Items.Count);

  WhatDraw := 'Z3';
  Tr := True;
  LPaint;
  FocusOnTask;
end;

procedure TFormcorners100k.FormShow(Sender: TObject);
