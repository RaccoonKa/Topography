procedure TFormcoords100k.FocusOnFlag;
begin
  if TaskStage = 1 then
  begin
    ScrollBox1.HorzScrollBar.Position := Round(FixFX * zoom) - (ScrollBox1.ClientWidth div 2);
    ScrollBox1.VertScrollBar.Position := Round(FixFY * zoom) - (ScrollBox1.ClientHeight div 2);
  end
  else
  begin
    ScrollBox1.HorzScrollBar.Position := Round(FixFX2 * zoom) - (ScrollBox1.ClientWidth div 2);
    ScrollBox1.VertScrollBar.Position := Round(FixFY2 * zoom) - (ScrollBox1.ClientHeight div 2);
  end;
end;

procedure TFormcoords100k.UpdateControlsVisibility;
begin

  PanelGeo.Visible := False;
  PanelRect.Visible := False;
  PanelAngles.Visible := False;

  case TaskStage of
    1: PanelGeo.Visible := True;
    2: PanelRect.Visible := True;
    3: PanelAngles.Visible := True;
  end;

  ButtonFinish.Visible := (TaskStage = 3);
  ButtonNext.Visible := (TaskStage <> 3);
  BitBtn1.Visible := (TaskStage <> 3);
  BitBtnProtractor.Visible := (TaskStage = 3);
end;

