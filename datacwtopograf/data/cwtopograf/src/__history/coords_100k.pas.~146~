procedure TFormcoords100k.Image1MouseDown(Sender: TObject; Button: TMouseButton;
  Shift: TShiftState; X, Y: Integer);
begin
  ScrollingDownY:=Y;
  ScrollingDownPositionY:=ScrollBox1.VertScrollBar.Position;
  ScrollingDownX:=X;
  ScrollingDownPositionX:=ScrollBox1.HorzScrollBar.Position;
end;

procedure TFormcoords100k.Image1MouseMove(Sender: TObject; Shift: TShiftState; X,
  Y: Integer);
begin
  MouseX:=x;
  MouseY:=y;
  if (whatDraw <> '0') or FixL or (TaskStage = 3) then
    Lpaint;
  if ssLeft in Shift then
  begin
    ScrollBox1.VertScrollBar.Position:=ScrollingDownPositionY+(ScrollingDownY-Y);
    ScrollingDownPositionY:= ScrollBox1.VertScrollBar.Position;
    ScrollBox1.HorzScrollBar.Position:=ScrollingDownPositionX+(ScrollingDownX-X);
    ScrollingDownPositionX:= ScrollBox1.HorzScrollBar.Position;
    ScrollBox1.Update;
    Scrolling:=True;
  end;
end;

procedure TFormcoords100k.Image1MouseUp(Sender: TObject; Button: TMouseButton;
  Shift: TShiftState; X, Y: Integer);
begin
  if not Scrolling then
  begin
    if whatDraw = 'L' then
    begin
      Image1.Cursor := crDefault;
      FixL := true;
      FixLx := Round(MouseX / zoom);
      FixLy := Round(MouseY / zoom);
      FixSpin := Spin;
      whatDraw := '0'
    end;
    if FixL and (Button = mbRight) then
    begin
      whatDraw := 'L';
      FixL := false;
      Lpaint;
    end;

    if (TaskStage = 3) and Tr then
    begin
      if (Button = mbLeft) and (not FixTr) then
      begin
        FixTr := True;
        FixTrX := MouseX;
        FixTrY := MouseY;
      end
      else if (Button = mbRight) and FixTr then
      begin
        FixTr := False;
        Lpaint;
      end;
    end;
  end
  else Scrolling := False;
end;

Procedure TFormcoords100k.LPaint;
var i: integer;
    tipX, tipY: Integer;
    path: TGPGraphicsPath;
    solidBrush: TGPSolidBrush;
    fontFamily: TGPFontFamily;
    font: TGPFont;
begin
  T1:=now;
  graphicsGDIPlus:= TGPGraphics.Create(Image1.Canvas.Handle);
  GraphicsGDIPlus.SetInterpolationMode(InterpolationModeHighQualityBicubic);
  R.X := 0 ;  R.Y :=0;
  R.Width := Round(2043*zoom);  R.Height := Round(2566*zoom);
  graphicsGDIPlus.SetSmoothingMode(SmoothingModeAntiAlias);
  graphicsGDIPlus.DrawCachedBitmap(cBitMap,0,0);

  if FixZ='Z1' then graphicsGDIPlus.DrawImage(znak1,FixFX*zoom-ZNAK1_OFFSET,FixFy*zoom-ZNAK1_OFFSET,ZNAK1_SIZE,ZNAK1_SIZE);
  if FixZ='Z2' then graphicsGDIPlus.DrawImage(znak2,FixFX*zoom-36,FixFy*zoom-63,75,75);
  if FixZ='Z3' then graphicsGDIPlus.DrawImage(znak3,FixFX*zoom-75,FixFy*zoom-38,75,75);
  if FixZ='Z4' then graphicsGDIPlus.DrawImage(znak4,FixFX*zoom-37,FixFy*zoom-62,75,75);

  if TaskStage >= 2 then
  begin
    if TaskStage = 3 then
    begin
      tipX := Round(FixFX2 * zoom - 2);
      tipY := Round(FixFY2 * zoom + 12);
      graphicsGDIPlus.DrawLine(pen, Round(FixFX * zoom), Round(FixFY * zoom), tipX, tipY);
    end;

    if FixZ2='Z1' then graphicsGDIPlus.DrawImage(znak1,FixFX2*zoom-ZNAK1_OFFSET,FixFy2*zoom-ZNAK1_OFFSET,ZNAK1_SIZE,ZNAK1_SIZE);
    if FixZ2='Z2' then graphicsGDIPlus.DrawImage(znak2,FixFX2*zoom-36,FixFy2*zoom-63,75,75);
    if FixZ2='Z3' then graphicsGDIPlus.DrawImage(znak3,FixFX2*zoom-75,FixFy2*zoom-38,75,75);
    if FixZ2='Z4' then graphicsGDIPlus.DrawImage(znak4,FixFX2*zoom-37,FixFy2*zoom-62,75,75);
  end;

  if (TaskStage = 3) and Tr then
  begin
    if FixTr then
      graphicsGDIPlus.TranslateTransform(FixTrX, FixTrY)
    else
      graphicsGDIPlus.TranslateTransform(MouseX, MouseY);
    graphicsGDIPlus.RotateTransform(-spin);
    graphicsGDIPlus.DrawImage(Transportir, -250, -150);
    graphicsGDIPlus.ResetTransform;
  end;

  if fixL then
  begin
    graphicsGDIPlus.TranslateTransform(FixLX*zoom,FixLY*zoom);
    graphicsGDIPlus.ScaleTransform(zoom*Lzoom,zoom*Lzoom);
    graphicsGDIPlus.RotateTransform(-Fixspin);
    path := TGPGraphicsPath.Create;
    try
      solidBrush := TGPSolidBrush.Create(MakeColor(200,255,255,255));
      try
        path.Reset;
        path.StartFigure();
        path.AddLine(-70,-40,150,-40);
        path.AddLine(150,-40,-70,100);
        path.AddLine(-70,100,-70,-40);
        path.AddLine(-40,-10,60,-10);
        path.AddLine(60,-10,-40,50);
        path.AddLine(-40,50,-40,-10);
        path.CloseFigure();
        graphicsGDIPlus.FillPath(solidBrush, path);

        graphicsGDIPlus.DrawLine(LinePen, -70,-40,150,-40);
        graphicsGDIPlus.DrawLine(LinePen, 150,-40,-70,100);
        graphicsGDIPlus.DrawLine(LinePen, -70,100,-70,-40);
        graphicsGDIPlus.DrawLine(LinePen, -40,-10,60,-10);
        graphicsGDIPlus.DrawLine(LinePen, 60,-10,-40,50);
        graphicsGDIPlus.DrawLine(LinePen, -40,50,-40,-10);
      finally
        solidBrush.Free;
      end;

      for i:=1 to 100 do
      begin
        if i mod 5 = 0 then
          graphicsGDIPlus.DrawLine(LinePen, i*2-70, -40, i*2-70, -33)
        else
          graphicsGDIPlus.DrawLine(LinePen, i*2-70, -40, i*2-70, -35);
      end;

      fontFamily := TGPFontFamily.Create('Times New Roman');
      font := TGPFont.Create(fontFamily, 9, FontStyleRegular, UnitPixel);
      solidBrush := TGPSolidBrush.Create(MakeColor(255,0,0,0));
      try
        for i:=1 to 9 do
        begin
          graphicsGDIPlus.SetTextRenderingHint(TextRenderingHintAntiAlias);
          graphicsGDIPlus.DrawString(IntToStr(i), -1, font, MakePoint(i*20-74, -33.0), solidBrush);
        end;
      finally
        fontFamily.Free;
        font.Free;
        solidBrush.Free;
      end;
    finally
      path.Free;
      graphicsGDIPlus.ResetTransform;
    end;
  end;

  if (whatDraw='L') then
  begin
    graphicsGDIPlus.TranslateTransform(Mousex,MouseY);
    graphicsGDIPlus.ScaleTransform(zoom*Lzoom,zoom*Lzoom);
    graphicsGDIPlus.RotateTransform(-spin);
    path := TGPGraphicsPath.Create;
    try
      solidBrush := TGPSolidBrush.Create(MakeColor(200,255,255,255));
      try
        path.Reset;
        path.StartFigure();
        path.AddLine(-70,-40,150,-40);
        path.AddLine(150,-40,-70,100);
        path.AddLine(-70,100,-70,-40);
        path.AddLine(-40,-10,60,-10);
        path.AddLine(60,-10,-40,50);
        path.AddLine(-40,50,-40,-10);
        path.CloseFigure();
        graphicsGDIPlus.FillPath(solidBrush, path);

        graphicsGDIPlus.DrawLine(LinePen, -70,-40,150,-40);
        graphicsGDIPlus.DrawLine(LinePen, 150,-40,-70,100);
        graphicsGDIPlus.DrawLine(LinePen, -70,100,-70,-40);
        graphicsGDIPlus.DrawLine(LinePen, -40,-10,60,-10);
        graphicsGDIPlus.DrawLine(LinePen, 60,-10,-40,50);
        graphicsGDIPlus.DrawLine(LinePen, -40,50,-40,-10);
      finally
        solidBrush.Free;
      end;

      for i:=1 to 100 do
      begin
        if i mod 5 = 0 then
          graphicsGDIPlus.DrawLine(LinePen, i*2-70, -40, i*2-70, -33)
        else
          graphicsGDIPlus.DrawLine(LinePen, i*2-70, -40, i*2-70, -35);
      end;

      fontFamily := TGPFontFamily.Create('Times New Roman');
      font := TGPFont.Create(fontFamily, 9, FontStyleRegular, UnitPixel);
      solidBrush := TGPSolidBrush.Create(MakeColor(255,0,0,0));
      try
        for i:=1 to 9 do
        begin
          graphicsGDIPlus.SetTextRenderingHint(TextRenderingHintAntiAlias);
          graphicsGDIPlus.DrawString(IntToStr(i), -1, font, MakePoint(i*20-74, -33.0), solidBrush);
        end;
      finally
        fontFamily.Free;
        font.Free;
        solidBrush.Free;
      end;
    finally
      path.Free;
      graphicsGDIPlus.ResetTransform;
    end;
  end;

  Image1.Repaint;

  T2:=now;
  DecodeTime(T2-T1,h,m,s,ms);
  Caption:=(IntToStr(s)+':'+IntToStr(ms)+'  '+IntToStr(Mousex)+'x'+IntToStr(Mousey)+
    '  '+FloatToStrF((8380+((Mousex/zoom-x1)*xx1/det+(Mousey/zoom-y1)*yy1/det)), ffFixed, 8, 1)+'x'+
    FloatToStrF((6320-((Mousex/zoom-x1)*xx2/det+(Mousey/zoom-y1)*yy2/det)), ffFixed, 8, 1)+
    '   '+ FloatToStrF(ScrollBox1.VertScrollBar.Range, ffFixed, 8, 1)+' '+
    FloatToStrF(ScrollBox1.VertScrollBar.Position+ScrollBox1.ClientHeight, ffFixed, 8, 1));
end;

procedure TFormcoords100k.FormKeyPress(Sender: TObject; var Key: Char);
begin
  if (key='+') then
  begin
    zoom:=zoom*1.1;
    Image1.Width:=Round(2043*zoom);
    Image1.Height:=Round(2566*zoom);
    Image1.Picture.Bitmap.Height := Round(2566*zoom);
    Image1.Picture.Bitmap.Width := Round(2043*zoom);

    WidthImage:=Round(2043*zoom);
    HightImage:=Round(2566*zoom);
    R.X :=  0 ;  R.Y := 0;
    R.Width := WidthImage;  R.Height := HightImage;
    Bitmap.Free;
    Bitmap:=TGPBitmap.Create(WidthImage,HightImage);
    graphicsGDIPlus:= TGPGraphics.Create(Bitmap);
    GraphicsGDIPlus.SetInterpolationMode(InterpolationModeHighQualityBicubic);
    graphicsGDIPlus.drawImage(Image,R);
    graphicsGDIPlus.Free;

    graphicsGDIPlus:= TGPGraphics.Create(Image1.Canvas.Handle);
    cBitmap.Free;
    cBitmap:= TGPCachedBitmap.Create(BitMap, graphicsGDIPlus);
    graphicsGDIPlus.DrawCachedBitmap(cBitMap,0,0);
    graphicsGDIPlus.Free;
    LPaint;
  end;

  if (key='-') then
  begin
    zoom:=zoom/1.1;
    Image1.Width:=Round(2043*zoom);
    Image1.Height:=Round(2566*zoom);
    Image1.Picture.Bitmap.Height := Round(2566*zoom);
    Image1.Picture.Bitmap.Width := Round(2043*zoom);

    WidthImage:=Round(2043*zoom);
    HightImage:=Round(2566*zoom);
    R.X :=  0 ;  R.Y := 0;
    R.Width := WidthImage;  R.Height := HightImage;
    Bitmap.Free;
