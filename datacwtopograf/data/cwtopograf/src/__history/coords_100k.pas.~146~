procedure LoadPngToGlyph(btn: TBitBtn; const FileName: string);
var
  png: TPngImage;
  bmp: TBitmap;
  gpBitmap: TGPBitmap;
  gpGraphics: TGPGraphics;
  destRect: TRect;
  pngStream: TMemoryStream;
begin
  if not FileExists(FileName) then Exit;
  png := TPngImage.Create;
  bmp := TBitmap.Create;
  pngStream := TMemoryStream.Create;
  try
    png.LoadFromFile(FileName);
    png.SaveToStream(pngStream);
    pngStream.Position := 0;
    gpBitmap := TGPBitmap.Create(TStreamAdapter.Create(pngStream));
    bmp.Width := btn.Width;
    bmp.Height := btn.Height;
    bmp.Canvas.Brush.Color := clBtnFace;
    bmp.Canvas.FillRect(Rect(0, 0, bmp.Width, bmp.Height));
    gpGraphics := TGPGraphics.Create(bmp.Canvas.Handle);
    try
      gpGraphics.SetInterpolationMode(InterpolationModeHighQualityBicubic);
      gpGraphics.SetSmoothingMode(SmoothingModeAntiAlias);
      gpGraphics.SetPixelOffsetMode(PixelOffsetModeHighQuality);
      if (gpBitmap.GetWidth > 0) and (gpBitmap.GetHeight > 0) then
      begin
        destRect := Rect(8, 8, bmp.Width - 8, bmp.Height - 8);
        if (Double(gpBitmap.GetWidth) / Double(gpBitmap.GetHeight)) > (destRect.Width / destRect.Height) then
        begin
          destRect.Bottom := destRect.Top + Round(destRect.Width * Double(gpBitmap.GetHeight) / Double(gpBitmap.GetWidth));
          OffsetRect(destRect, 0, (bmp.Height - destRect.Height) div 2 - 4);
        end
        else
        begin
          destRect.Right := destRect.Left + Round(destRect.Height * Double(gpBitmap.GetWidth) / Double(gpBitmap.GetHeight));
          OffsetRect(destRect, (bmp.Width - destRect.Width) div 2 - 4, 0);
        end;
      end
      else
        destRect := Rect(0, 0, bmp.Width, bmp.Height);
      gpGraphics.DrawImage(gpBitmap,
        MakeRect(destRect.Left, destRect.Top,
                 destRect.Right - destRect.Left,
                 destRect.Bottom - destRect.Top),
        0, 0, gpBitmap.GetWidth, gpBitmap.GetHeight, UnitPixel);
    finally
      gpGraphics.Free;
      gpBitmap.Free;
    end;
    btn.Glyph := bmp;
  finally
    pngStream.Free;
    png.Free;
    bmp.Free;
  end;
end;

