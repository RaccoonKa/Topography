procedure TFormcoords100k.ButtonNextClick(Sender: TObject);
var
  dx, dy, px, py: integer;
  kx, ky, shirota, dolgota, delta_shirota, delta_dolgota: real;
  RealGX, RealGY: Double;
  UserX, UserY, DiffX, DiffY: Double;
  ZoneText: string;
begin
  FixL := False;
  whatDraw := '0';
  FixTr := False;

  if TaskStage = 1 then
  begin
    dx := 120;
    dy := 134;
    px := fixfx - dx;
    py := fixfy - dy;
    kx := 1800 / 1795;
    ky := 3600 / 2189;

    shirota := StrToFloatDef(edit4.text, 0)*3600 + StrToFloatDef(edit5.text, 0)*60 + StrToFloatDef(edit6.text, 0);
    dolgota := StrToFloatDef(edit7.text, 0)*3600 + StrToFloatDef(edit8.text, 0)*60 + StrToFloatDef(edit9.text, 0);

    delta_shirota := shirota - (56*3600+40*60+(2189-py)*ky) + 2400*(2189-py)/2189;
    delta_dolgota := dolgota - (43*3600+px*kx);
    TempGeoResult := 'Географические координаты: Ошибка по широте ' + FloatToStr(RoundTo(delta_shirota, -1)) +
                    '" ; по долготе ' + FloatToStr(RoundTo(delta_dolgota, -1)) + '".';

    repeat
      FixFX2 := 250 + Random(1300);
      FixFY2 := 250 + Random(1900);
    until sqrt(sqr(FixFX2 - FixFX) + sqr(FixFY2 - FixFY)) > 200;

    FixZ2 := 'Z2';
    TaskStage := 2;
    UpdateControlsVisibility;
    ButtonNext.Caption := 'Третье задание';

    LPaint;
    FocusOnFlag;
  end
  else if TaskStage = 2 then
  begin
    RealGX := 8380 + ((FixFX2 - x1) * xx1 / det + (FixFY2 - y1) * yy1 / det);
    RealGY := 6320 - ((FixFX2 - x1) * xx2 / det + (FixFY2 - y1) * yy2 / det);

    UserX := StrToFloatDef(Edit2.Text, 0) / 1000.0;
    UserY := StrToFloatDef(Edit1.Text, 0) / 1000.0;

    DiffX := Abs(UserX - RealGX) * 1000;
    DiffY := Abs(UserY - RealGY) * 1000;

    if Trim(Edit3.Text) = '8' then
      ZoneText := 'верно'
    else
      ZoneText := 'неверно';

    TempRectResult := Format('Прямоугольные координаты: Ошибка по X: %.1f м; по Y: %.1f м. Зона: %s.',
                             [DiffX, DiffY, ZoneText]);

    TaskStage := 3;
    Tr := False;
    whatDraw := '0';
    UpdateControlsVisibility;
    ButtonNext.Visible := False;
    LPaint;
    FocusOnFlag;
  end;
end;

procedure TFormcoords100k.ButtonFinishClick(Sender: TObject);
var
  i, j, q: integer;
  ResultMsg: string;
  R: array[1..4] of array[1..6] of string;
  U: array[1..4] of double;
  dat: array[1..4] of double;
begin
  if FixFX2 >= FixFX then
    dat[2] := 0.16 + 180 / 3.1415 * ArcCos((FixFY - FixFY2) / sqrt((FixFX2 - FixFX) * (FixFX2 - FixFX) + (FixFY2 - FixFY) * (FixFY2 - FixFY)))
  else
    dat[2] := 0.16 + 180 + 180 / 3.1415 * ArcCos((FixFY2 - FixFY) / sqrt((FixFX - FixFX2) * (FixFX - FixFX2) + (FixFY2 - FixFY) * (FixFY2 - FixFY)));

  R[1][1] := Edit10.Text;  R[1][2] := Edit11.Text;
  R[2][1] := Edit12.Text;  R[2][2] := Edit13.Text;
  R[3][1] := Edit14.Text;  R[3][2] := Edit15.Text;
  R[4][1] := Edit16.Text;  R[4][2] := Edit17.Text;

  if dat[2] + 1.467 < 360 then dat[1] := (dat[2] + 1.467) else dat[1] := (dat[2] + 1.467) - 360;

  if dat[2] - 9.4 >= 0 then dat[3] := (dat[2] - 9.4) else dat[3] := 360 + (dat[2] - 9.4); // Исправлен баг

  if Length(ComboBox2.Text) <> 0 then dat[4] := (StrToIntDef(ComboBox2.Text, 2015) - 1983) / 60
  else begin ComboBox2.Text := '2015'; dat[4] := (2015 - 1983) / 60; end;

  for i := 1 to 4 do
  begin
    if Length(TrimLeft(R[i][1])) = 0 then R[i][1] := '0';
    if Length(TrimLeft(R[i][2])) = 0 then R[i][2] := '0';
    U[i] := StrToFloatDef(R[i][1], 0) + StrToFloatDef(R[i][2], 0) / 60;
  end;

  for i := 1 to 4 do
  begin
    if Abs(U[i] - dat[i]) < (360 - Abs(U[i] - dat[i])) then
    begin
      R[i][3] := IntToStr(Trunc(Abs(U[i] - dat[i])));
      R[i][4] := IntToStr(Trunc((Abs(U[i] - dat[i]) - StrToFloatDef(R[i][3], 0)) * 60));
    end
    else
    begin
      R[i][3] := IntToStr(Trunc(360 - Abs(U[i] - dat[i])));
      R[i][4] := IntToStr(Trunc((360 - Abs(U[i] - dat[i]) - StrToFloatDef(R[i][3], 0)) * 60));
    end;
  end;

  if ComboBox1.ItemIndex = 0 then q := 1 else if ComboBox1.ItemIndex = 1 then q := -1 else q := 0;

  if Abs(q * U[4] - dat[4]) < (360 - Abs(q * U[4] - dat[4])) then
  begin
    R[4][3] := IntToStr(Trunc(Abs(q * U[4] - dat[4])));
    R[4][4] := IntToStr(Round((Abs(q * U[4] - dat[4]) - StrToFloatDef(R[4][3], 0)) * 60));
  end
  else
  begin
    R[4][3] := IntToStr(Trunc(360 - Abs(q * U[4] - dat[4])));
    R[4][4] := IntToStr(Round((360 - Abs(q * U[4] - dat[4]) - StrToFloatDef(R[4][3], 0)) * 60));
  end;

  for i := 1 to 4 do
  begin
    for j := 1 to (6 - Length(TrimLeft(R[i][3]))) do R[i][3] := '  ' + R[i][3];
    for j := 1 to (2 - Length(TrimLeft(R[i][4]))) do R[i][4] := '  ' + R[i][4];
  end;

  for i := 1 to 3 do
  begin
    if (StrToFloatDef(Trim(R[i][3]), 0) + StrToFloatDef(Trim(R[i][4]), 0) / 60) <= 1.2 then R[i][5] := '✓' else R[i][5] := '✕';
    for j := 1 to 12 do R[i][5] := ' ' + R[i][5];
  end;

  if (StrToFloatDef(Trim(R[4][3]), 0) + StrToFloatDef(Trim(R[4][4]), 0) / 60) <= 0.02 then R[4][5] := '✓' else R[4][5] := '✕';
  for j := 1 to 12 do R[4][5] := ' ' + R[4][5];

  ResultMsg :=
    'Дирекционный угол:       ' + Trim(R[1][1]) + '° ' + Trim(R[1][2]) + #39 + ' | Ошибка: ' + Trim(R[1][3]) + '° ' + Trim(R[1][4]) + #39 + ' | ' + Trim(R[1][5]) + sLineBreak +
    'Истинный азимут:         ' + Trim(R[2][1]) + '° ' + Trim(R[2][2]) + #39 + ' | Ошибка: ' + Trim(R[2][3]) + '° ' + Trim(R[2][4]) + #39 + ' | ' + Trim(R[2][5]) + sLineBreak +
    'Магнитный азимут:        ' + Trim(R[3][1]) + '° ' + Trim(R[3][2]) + #39 + ' | Ошибка: ' + Trim(R[3][3]) + '° ' + Trim(R[3][4]) + #39 + ' | ' + Trim(R[3][5]) + sLineBreak +
    'Изменение м-го азимута:  ' + Trim(R[4][1]) + '° ' + Trim(R[4][2]) + #39 + ' | Ошибка: ' + Trim(R[4][3]) + '° ' + Trim(R[4][4]) + #39 + ' | ' + Trim(R[4][5]);

  PracticeCoordsDone := True;
  PracticeCornersDone := True;
  PracticeCoordsResultStr := TempGeoResult;
  PracticeCornersResultStr := ResultMsg;
  PracticeRectDone := True;
  PracticeRectResultStr := TempRectResult;
  Self.Close;
end;

