procedure TSpeedButton.CMMouseEnter(var Message: TMessage);
begin
  inherited;
  FMouseIn := True;
  Invalidate;
end;

procedure TSpeedButton.CMMouseLeave(var Message: TMessage);
begin
  inherited;
  FMouseIn := False;
  Invalidate;
end;

