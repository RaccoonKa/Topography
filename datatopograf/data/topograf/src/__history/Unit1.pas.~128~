procedure TForm1.qMouseUp(Sender: TObject; Button: TMouseButton;
Shift: TShiftState; X, Y: Integer);
begin
  Timer2.Enabled:=true;
  MediaPlayer1.Position:=Bar.Position;
  if not Pause then
    MediaPlayer1.Play;
    Down:=false;
end;

procedure TForm1.qMouseDown(Sender: TObject; Button: TMouseButton;
Shift: TShiftState; X, Y: Integer);
var
  P:TPoint;
begin
  Timer2.Enabled:=false;
  Down:=true;
  MediaPlayer1.Pause;
  Bar.Position:=Round((x-11)/(Bar.Width-22)*(Bar.Max));
  GetCursorPos(P);
  P := Form1.ScreenToClient(P);
  MediaPlayer1.Position:=Bar.Position;
end;

procedure TForm1.qMouseMove(Sender: TObject; Shift: TShiftState; X, Y: Integer);
begin
  if Down then
    begin
      Bar.Position:=Round((x-11)/(Bar.Width-22)*(Bar.Max));
      MediaPlayer1.Position:=Bar.Position;
      MediaPlayer1.play;
      MediaPlayer1.pause;
    end;
  Caption:=inttostr(x);
end;

