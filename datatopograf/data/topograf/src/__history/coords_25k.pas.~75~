procedure TFormcoords25k.LoadPoints(FileName: string);
var
  t: TextFile;
  s: string;
  parts: TStringList;
  fs: TFormatSettings;
begin
  if not FileExists(FileName) then Exit;
  fs := TFormatSettings.Invariant;

  AssignFile(t, FileName);
  Reset(t);
  parts := TStringList.Create;
  parts.Delimiter := ';';
  try
    SetLength(Points, 0);
    while not Eof(t) do begin
      Readln(t, s);
      parts.DelimitedText := s;
      if parts.Count = 4 then begin
        SetLength(Points, Length(Points) + 1);
        Points[High(Points)].px := StrToFloat(parts[0], fs);
        Points[High(Points)].py := StrToFloat(parts[1], fs);
        Points[High(Points)].gx := StrToFloat(parts[2], fs);
        Points[High(Points)].gy := StrToFloat(parts[3], fs);
      end;
    end;
  finally
    parts.Free;
    CloseFile(t);
  end;
end;

procedure TFormcoords25k.PixelToGeo(px, py: Double; var GeoX, GeoY: Double);
var
  i, j: Integer;
  Dist: array of Double;
  Idx: array of Integer;
  tmpD: Double;
  tmpI: Integer;
  p1, p2, p3: Integer;
  x1, y1, x2, y2, x3, y3: Double;
  gx1, gy1, gx2, gy2, gx3, gy3: Double;
  det, L1, L2, L3: Double;
begin
  GeoX := 0;
  GeoY := 0;

  if Length(Points) < 3 then Exit;

  SetLength(Dist, Length(Points));
  SetLength(Idx, Length(Points));

  for i := 0 to High(Points) do
  begin
    Dist[i] := Sqrt(Sqr(px - Points[i].px) + Sqr(py - Points[i].py));
    Idx[i] := i;
  end;

  for i := 0 to High(Dist) - 1 do
    for j := i + 1 to High(Dist) do
      if Dist[j] < Dist[i] then
      begin
        tmpD := Dist[i]; Dist[i] := Dist[j]; Dist[j] := tmpD;
        tmpI := Idx[i]; Idx[i] := Idx[j]; Idx[j] := tmpI;
      end;

  p1 := Idx[0];
  p2 := Idx[1];
  p3 := -1;

  for i := 2 to High(Idx) do
  begin
    x1 := Points[p1].px; y1 := Points[p1].py;
    x2 := Points[p2].px; y2 := Points[p2].py;
    x3 := Points[Idx[i]].px; y3 := Points[Idx[i]].py;

    det := (y2 - y3)*(x1 - x3) + (x3 - x2)*(y1 - y3);
    if Abs(det) > 10.0 then
    begin
      p3 := Idx[i];
      Break;
    end;
  end;

  if p3 = -1 then p3 := Idx[2];

  x1 := Points[p1].px; y1 := Points[p1].py; gx1 := Points[p1].gx; gy1 := Points[p1].gy;
  x2 := Points[p2].px; y2 := Points[p2].py; gx2 := Points[p2].gx; gy2 := Points[p2].gy;
  x3 := Points[p3].px; y3 := Points[p3].py; gx3 := Points[p3].gx; gy3 := Points[p3].gy;

  det := (y2 - y3)*(x1 - x3) + (x3 - x2)*(y1 - y3);
  if Abs(det) < 0.001 then Exit;

  L1 := ((y2 - y3)*(px - x3) + (x3 - x2)*(py - y3)) / det;
  L2 := ((y3 - y1)*(px - x3) + (x1 - x3)*(py - y3)) / det;
  L3 := 1.0 - L1 - L2;

  GeoX := L1 * gx1 + L2 * gx2 + L3 * gx3;
  GeoY := L1 * gy1 + L2 * gy2 + L3 * gy3;
end;



procedure TFormcoords25k.FormKeyPress(Sender: TObject; var Key: Char);
var
  NewZoom: Real;
  NewW, NewH: Integer;
  NewBitmap: TGPBitmap;
  NewCached: TGPCachedBitmap;
  NewGraphics, TempGraphics: TGPGraphics;
begin
  if FZoomActive then Exit;
  if (Key <> '+') and (Key <> '-') then Exit;

  FZoomActive := True;
  try
    if Key = '+' then
      NewZoom := zoom * 1.1
    else
      NewZoom := zoom / 1.1;

    NewW := Round(2133 * NewZoom);
    NewH := Round(2679 * NewZoom);

    NewBitmap := TGPBitmap.Create(NewW, NewH);
    try
      NewGraphics := TGPGraphics.Create(NewBitmap);
      try
        NewGraphics.SetInterpolationMode(InterpolationModeHighQualityBicubic);
        NewGraphics.DrawImage(Image, 0, 0, NewW, NewH);
      finally
        NewGraphics.Free;
      end;

      TempGraphics := TGPGraphics.Create(Image1.Canvas.Handle);
      try
        NewCached := TGPCachedBitmap.Create(NewBitmap, TempGraphics);
      finally
        TempGraphics.Free;
      end;
    except
      NewBitmap.Free;
      raise;
    end;

    cBitmap.Free;
    cBitmap := NewCached;

    Bitmap.Free;
    Bitmap := NewBitmap;

    zoom := NewZoom;
    Image1.Width  := NewW;
    Image1.Height := NewH;
    WidthImage  := NewW;
    HightImage  := NewH;
    R.X := 0; R.Y := 0; R.Width := NewW; R.Height := NewH;

    LPaint;
  finally
    FZoomActive := False;
  end;
end;

procedure TFormcoords25k.FormMouseWheelDown(Sender: TObject; Shift: TShiftState;
  MousePos: TPoint; var Handled: Boolean);
begin
  if FZoomActive then Exit;
  if (whatDraw = 'L') or FixL then
  begin
    if CtrlDown then
      spin := spin - 0.1
    else
      spin := spin - 4;

    LPaint;
    Handled := True;
  end;
end;

procedure TFormcoords25k.FormMouseWheelUp(Sender: TObject; Shift: TShiftState;
  MousePos: TPoint; var Handled: Boolean);
begin
  if FZoomActive then Exit;
  if (whatDraw = 'L') or FixL then
  begin
    if CtrlDown then
      spin := spin + 0.1
    else
      spin := spin + 4;

    LPaint;
    Handled := True;
