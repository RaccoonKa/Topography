procedure TFormcoords25k.BTestClick(Sender: TObject);
var
  text: string;
  RealGX, RealGY: Double;
  UserX, UserY, ErrorDist: Double;
begin
  if Edit3.Text = '4' then
    text := 'Номер зоны определен верно.'
  else
    text := 'Номер зоны определен неверно.';

  PixelToGeo(FixFX, FixFY, RealGX, RealGY);
  if (RealGX = 0) and (RealGY = 0) then
  begin
    MessageBox(Self.Handle, 'Ошибка: Нет данных для расчета. Проверьте файл coords25k.txt', 'Внимание', MB_OK or MB_ICONERROR);
    Exit;
  end;

  try
    UserX := StrToFloat(Edit1.Text) / 1000.0;
    UserY := StrToFloat(Edit2.Text) / 1000.0;
  except
    MessageBox(Self.Handle, 'Пожалуйста, введите корректные числовые значения в поля X и Y.', 'Ошибка ввода', MB_OK or MB_ICONWARNING);
    Exit;
  end;

  ErrorDist := Sqrt(Sqr(UserX - RealGX) + Sqr(UserY - RealGY));

  MessageBox(Self.Handle, PChar('Ошибка составляет ' + FloatToStrF(ErrorDist, ffFixed, 8, 3) + ' км. ' + text + #13 +
    '                              ПОЗОВИТЕ ПРЕПОДАВАТЕЛЯ'), PChar('Результаты'), MB_OK or MB_ICONINFORMATION or MB_TOPMOST or MB_TASKMODAL);
end;

procedure TFormcoords25k.Button1Click(Sender: TObject);
var
  dx : integer;
  dy : integer;
  px : integer;
  py : integer;
  kx, ky : real;
  dolgota : real;
  shirota : real;
  delta_shirota, delta_dolgota : real;
  calc_lat, calc_lon : real;
begin
  if FixZ = '' then
  begin
    MessageBox(Self.Handle,
      'Ты конечно молодец...Но флажок установить-то надо)))',
      'Внимание', MB_OK or MB_ICONWARNING);
    Exit;
  end;

  try
    shirota := StrToFloat(Edit4.Text)*3600 + StrToFloat(Edit5.Text)*60 + StrToFloat(Edit6.Text);
    dolgota := StrToFloat(Edit7.Text)*3600 + StrToFloat(Edit8.Text)*60 + StrToFloat(Edit9.Text);
  except
    MessageBox(Self.Handle,
      'Пожалуйста, введите корректные значения градусов, минут и секунд.',
      'Ошибка ввода', MB_OK or MB_ICONWARNING);
    Exit;
  end;

  dx := 110;
  dy := 225;

  px := fixfx - dx;
  py := fixfy - dy;

  kx := 450 / 1906;
  ky := 300 / 2197;

  calc_lat := (54*3600 + 45*60) - (py * ky);
  calc_lon := (18*3600 +  0*60) + (px * kx);

  delta_shirota := shirota - calc_lat;
  delta_dolgota := dolgota - calc_lon;

  MessageBox(Self.Handle,
    PChar('Ошибка по широте: ' + FloatToStr(RoundTo(delta_shirota, -1)) +
          '" ; по долготе: ' + FloatToStr(RoundTo(delta_dolgota, -1)) + '".'),
    'Результат', MB_OK or MB_ICONINFORMATION);
end;

