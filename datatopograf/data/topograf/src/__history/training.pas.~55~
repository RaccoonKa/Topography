procedure TFormtraining.Timer1Timer(Sender: TObject);
begin
  if N = 3 then
    N := 0;
  N := N + 1;
  Image1.Picture.Bitmap := Images1[N];
  MediaPlayer1.Play;
  Timer1.Enabled := True;
end;

procedure TFormtraining.Timer2Timer(Sender: TObject);
var
  P: Integer;
begin
  if not Visible then Exit;
  Bar.Max := MediaPlayer1.TrackLength[1];
  Bar.Position := MediaPlayer1.Position;
  P := MediaPlayer1.Position;
  if (P < 36300) and (Label1.Caption <> 'Шаг: 1') then
  begin
    Label1.Caption := 'Шаг: 1';
    RichEdit1.Lines.Clear;
    RichEdit1.Lines.LoadFromFile('..\data\topograf\assets\extras\rec\instruction 1.rtf');
  end;
  if (P >= 36300) and (P < 43000) and (Label1.Caption <> 'Шаг: 2') then
  begin
    Label1.Caption := 'Шаг: 2';
    RichEdit1.Lines.Clear;
    RichEdit1.Lines.LoadFromFile('..\data\topograf\assets\extras\rec\instruction 2.rtf');
  end;
  if (P >= 43000) and (P < 53210) and (Label1.Caption <> 'Шаг: 3') then
  begin
    Label1.Caption := 'Шаг: 3';
    RichEdit1.Lines.Clear;
    RichEdit1.Lines.LoadFromFile('..\data\topograf\assets\extras\rec\instruction 3.rtf');
  end;
  if (P >= 53210) and (P < 82200) and (Label1.Caption <> 'Шаг: 4') then
  begin
    Label1.Caption := 'Шаг: 4';
    RichEdit1.Lines.Clear;
    RichEdit1.Lines.LoadFromFile('..\data\topograf\assets\extras\rec\instruction 4.rtf');
  end;
  if (P >= 82200) and (Label1.Caption <> 'Шаг: 5') then
  begin
    Label1.Caption := 'Шаг: 5';
    RichEdit1.Lines.Clear;
    RichEdit1.Lines.LoadFromFile('..\data\topograf\assets\extras\rec\instruction 5.rtf');
  end;
end;

procedure TFormtraining.TrackBar1Change(Sender: TObject);
begin
  // заглушка
