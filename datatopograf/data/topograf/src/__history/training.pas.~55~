procedure TFormtraining.SpeedButton1Click(Sender: TObject);
var
  P, i: Integer;
  M: array[1..6] of Integer;
begin
  M[1] := 0;
  M[2] := 36300;
  M[3] := 43000;
  M[4] := 53210;
  M[5] := 82200;
  M[6] := MediaPlayer1.TrackLength[1];
  P := MediaPlayer1.Position;
  for i := 1 to 5 do
  begin
    if (P >= M[i]) and (P < M[i+1]) then
    begin
      if not Pause then
      begin
        MediaPlayer1.Position := M[i];
        MediaPlayer1.Play;
      end
      else
        MediaPlayer1.Position := M[i];
    end;
  end;
end;

