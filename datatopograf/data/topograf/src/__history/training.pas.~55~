procedure TFormtraining.SpeedButton3Click(Sender: TObject);
begin
  if Pause then
  begin
    if MediaPlayer1.Mode = mpNotReady then
      MediaPlayer1.Open;
    MediaPlayer1.TimeFormat := tfMilliseconds;
    if MediaPlayer1.Position = MediaPlayer1.Length then
      MediaPlayer1.Position := 0;
    Bar.Enabled := True;
    Panel1.Visible := True;
    MediaPlayer1.Play;
    Timer2.Enabled := True;
  end
  else
    MediaPlayer1.Pause;
  Pause := not Pause;
end;

