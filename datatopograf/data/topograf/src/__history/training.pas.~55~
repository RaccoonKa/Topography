procedure TFormtraining.qMouseUp(Sender: TObject; Button: TMouseButton;
  Shift: TShiftState; X, Y: Integer);
begin
  Timer2.Enabled := True;
  MediaPlayer1.Position := Bar.Position;
  if not Pause then
    MediaPlayer1.Play;
  Down := False;
end;

procedure TFormtraining.qMouseDown(Sender: TObject; Button: TMouseButton;
  Shift: TShiftState; X, Y: Integer);
begin
  Timer2.Enabled := False;
  Down := True;
  MediaPlayer1.Pause;
  Bar.Position := Round((X - 11) / (Bar.Width - 22) * Bar.Max);
  MediaPlayer1.Position := Bar.Position;
end;

procedure TFormtraining.qMouseMove(Sender: TObject; Shift: TShiftState; X, Y: Integer);
begin
  if Down then
  begin
    Bar.Position := Round((X - 11) / (Bar.Width - 22) * Bar.Max);
    MediaPlayer1.Position := Bar.Position;
    MediaPlayer1.Play;
    MediaPlayer1.Pause;
  end;
end;

