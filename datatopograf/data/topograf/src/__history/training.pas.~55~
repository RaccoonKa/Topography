implementation

{$R *.dfm}

procedure TFormtraining.FormCreate(Sender: TObject);
var
  str: string;
  i: Integer;
begin
  Formtraining.Color := RGB(0, 0, 0);
  for i := 1 to 3 do
  begin
    str := '..\data\topograf\assets\slides\1' + IntToStr(i) + '.bmp';
    Images1[i] := TBitmap.Create;
    Images1[i].LoadFromFile(str);
  end;
  SpeedButton1.Glyph.LoadFromFile('..\data\topograf\assets\buttons_video\P61.bmp');
  SpeedButton5.Glyph.LoadFromFile('..\data\topograf\assets\buttons_video\P51.bmp');
  SpeedButton3.Glyph.LoadFromFile('..\data\topograf\assets\buttons_video\P11.bmp');
  SpeedButton2.Glyph.LoadFromFile('..\data\topograf\assets\buttons_video\P41.bmp');
  SpeedButton4.Glyph.LoadFromFile('..\data\topograf\assets\buttons_video\P31.bmp');
  RichEdit1.Clear;
  MediaPlayer1.TimeFormat := tfMilliseconds;

  Bar := TBar.Create(Self);
  Bar.Parent := Self;
  Bar.Top := 430;
  Bar.Left := 19;
  Bar.Width := 595;
  Bar.Height := 20;
  Bar.OnMouseUp := qMouseUp;
  Bar.OnMouseMove := qMouseMove;
  Bar.OnMouseDown := qMouseDown;
  Bar.Enabled := False;
  Bar.TabStop := False;
  Bar.Visible := False;

  Image1.Picture := nil;
  MediaPlayer1.Display := Panel1;

  SpeedButtonGeoPrev.Glyph.LoadFromFile('..\data\topograf\assets\buttons_video\P41.bmp');
  SpeedButtonGeoNext.Glyph.LoadFromFile('..\data\topograf\assets\buttons_video\P31.bmp');

  FMode := mdMenu;
  SetMode(mdMenu);
  Formtraining.Position := poScreenCenter;
end;

procedure TFormtraining.FormResize(Sender: TObject);
begin
  if Assigned(Bar) then
  begin
    Bar.Top := 430;
    Bar.Left := 19;
    Bar.Width := 595;
  end;
end;

procedure TFormtraining.FormShow(Sender: TObject);
begin
  SetMode(FMode);
end;

procedure TFormtraining.SetMode(AMode: TMode);
begin
  FMode := AMode;
  PanelMenu.Visible := (AMode = mdMenu);
  SpeedButton1.Visible := (AMode = mdRectangular);
  SpeedButton2.Visible := (AMode = mdRectangular);
  SpeedButton3.Visible := (AMode = mdRectangular);
  SpeedButton4.Visible := (AMode = mdRectangular);
  SpeedButton5.Visible := False;
  Bar.Visible := (AMode = mdRectangular);
  Bar.Enabled := (AMode = mdRectangular);
  Label1.Visible := (AMode <> mdMenu);
  RichEdit1.Visible := (AMode <> mdMenu);
  ImageGeo.Visible := (AMode = mdGeographic);
  SpeedButtonGeoPrev.Visible := (AMode = mdGeographic);
  SpeedButtonGeoNext.Visible := (AMode = mdGeographic);
  TrackBarGeo.Visible := (AMode = mdGeographic);
  btnBack.Visible := (AMode <> mdMenu);

  if AMode = mdRectangular then
  begin
    Bar.Top := 430;
    Bar.Left := 19;
    Bar.Width := 595;
  end;

  if AMode <> mdRectangular then
  begin
    if MediaPlayer1.Mode = mpPlaying then
      MediaPlayer1.Stop;
    Timer1.Enabled := False;
    Timer2.Enabled := False;
    Panel1.Visible := False;
  end;
end;

procedure TFormtraining.InitRectangular;
begin
  MediaPlayer1.FileName := '..\data\topograf\assets\extras\rec\instruction.mpg';
  MediaPlayer1.Open;
  MediaPlayer1.TimeFormat := tfMilliseconds;
  MediaPlayer1.Display := Panel1;
  N := 0;
  Down := False;
  Pause := True;
  FirstPlay := True;
  Panel1.Visible := False;
  RichEdit1.Lines.Clear;
  RichEdit1.Lines.LoadFromFile('..\data\topograf\assets\extras\rec\instruction.rtf');
  Label1.Caption := 'Шаг: 1';
end;

procedure TFormtraining.btnBackClick(Sender: TObject);
begin
  SetMode(mdMenu);
end;

procedure TFormtraining.btnRectangularClick(Sender: TObject);
begin
  InitRectangular;
  SetMode(mdRectangular);
end;

procedure TFormtraining.btnGeographicClick(Sender: TObject);
begin
  N_geo := 1;
  TrackBarGeo.Position := 0;
  LoadGeoStep(N_geo);
  SetMode(mdGeographic);
end;

procedure TFormtraining.LoadGeoStep(Step: Integer);
begin
  if Step < 1 then Step := 1;
  if Step > 4 then Step := 4;
  ImageGeo.Picture.LoadFromFile('..\data\topograf\assets\Slides\inst' + IntToStr(Step) + '.bmp');
  RichEdit1.Lines.Clear;
  RichEdit1.Lines.LoadFromFile('..\data\topograf\assets\extras\geo\instruction_' + IntToStr(Step) + '.rtf');
  Label1.Caption := 'Шаг: ' + IntToStr(Step) + '/4';
  N_geo := Step;
end;

procedure TFormtraining.SpeedButtonGeoPrevClick(Sender: TObject);
begin
  if N_geo > 1 then
  begin
    LoadGeoStep(N_geo - 1);
    TrackBarGeo.Position := N_geo - 1;
  end;
end;

procedure TFormtraining.SpeedButtonGeoNextClick(Sender: TObject);
begin
  if N_geo < 4 then
  begin
    LoadGeoStep(N_geo + 1);
    TrackBarGeo.Position := N_geo - 1;
  end;
end;

procedure TFormtraining.TrackBarGeoChange(Sender: TObject);
begin
  N_geo := TrackBarGeo.Position + 1;
  LoadGeoStep(N_geo);
end;

