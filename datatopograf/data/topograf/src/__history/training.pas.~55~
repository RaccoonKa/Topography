procedure TFormtraining.SpeedButton2Click(Sender: TObject);
var
  P, i: Integer;
  M: array[1..6] of Integer;
begin
  M[1] := 0;
  M[2] := 36300;
  M[3] := 43000;
  M[4] := 53210;
  M[5] := 82200;
  M[6] := MediaPlayer1.TrackLength[1];
  P := MediaPlayer1.Position;
  for i := 2 to 5 do
  begin
    if (P >= M[i]) and (P < M[i+1]) then
    begin
      if not Pause then
      begin
        MediaPlayer1.Position := M[i-1];
        MediaPlayer1.Play;
      end
      else
        MediaPlayer1.Position := M[i-1];
    end;
  end;
  if (P >= M[1]) and (P < M[2]) then
  begin
    if not Pause then
    begin
      MediaPlayer1.Position := M[1];
      MediaPlayer1.Play;
    end
    else
      MediaPlayer1.Position := M[1];
  end;
end;

