procedure TForm5.Button1Click(Sender: TObject);
var
  dx : integer;
  dy : integer;
  px : integer;
  py : integer;
  kx, ky : real;
  dolgota : real;
  shirota : real;
  l : real;
  delta_shirota, delta_dolgota : real;
  calc_lat, calc_lon : real;
begin

  dx := 110;
  dy := 225;

  px := fixfx - dx;
  py := fixfy - dy;

  kx := 450 / 1906;
  ky := 300 / 2197;

  shirota := strtofloat(edit4.text)*3600+strtofloat(edit5.text)*60+strtofloat(edit6.text);
  dolgota := strtofloat(edit7.text)*3600+strtofloat(edit8.text)*60+strtofloat(edit9.text);

  calc_lat := (54*3600 + 45*60) - (py * ky);
  calc_lon := (18*3600 + 0*60) + (px * kx);

  delta_shirota := shirota - calc_lat;
  delta_dolgota := dolgota - calc_lon;

  showmessage('Îřčáęŕ ďî řčđîňĺ: ' + floattostr(RoundTo(delta_shirota, -1)) + '" ; ďî äîëăîňĺ: ' + floattostr(RoundTo(delta_dolgota, -1)) + '".');
end;

