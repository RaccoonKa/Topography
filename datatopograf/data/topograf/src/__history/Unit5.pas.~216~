procedure TForm5.LoadPoints(FileName: string);
var
  t: TextFile;
  s: string;
  parts: TStringList;
  fs: TFormatSettings;
begin
  if not FileExists(FileName) then Exit;
  GetLocaleFormatSettings(0, fs);
  fs.DecimalSeparator := '.';

  AssignFile(t, FileName);
  Reset(t);
  parts := TStringList.Create;
  parts.Delimiter := ';';
  try
    SetLength(Points, 0);
    while not Eof(t) do begin
      Readln(t, s);
      parts.DelimitedText := s;
      if parts.Count = 4 then begin
        SetLength(Points, Length(Points) + 1);
        Points[High(Points)].px := StrToFloat(parts[0], fs);
        Points[High(Points)].py := StrToFloat(parts[1], fs);
        Points[High(Points)].gx := StrToFloat(parts[2], fs);
        Points[High(Points)].gy := StrToFloat(parts[3], fs);
      end;
    end;
  finally
    parts.Free;
    CloseFile(t);
  end;
end;

procedure TForm5.PixelToGeo(px, py: Double; var GeoX, GeoY: Double);
var
  i, j: Integer;
  Dist: array of Double;
  Idx: array of Integer;
  tmpD: Double;
  tmpI: Integer;
  p1, p2, p3: Integer;
  x1, y1, x2, y2, x3, y3: Double;
  gx1, gy1, gx2, gy2, gx3, gy3: Double;
  det, L1, L2, L3: Double;
begin
  GeoX := 0;
  GeoY := 0;

  if Length(Points) < 3 then Exit;

  SetLength(Dist, Length(Points));
  SetLength(Idx, Length(Points));

  for i := 0 to High(Points) do
  begin
    Dist[i] := Sqrt(Sqr(px - Points[i].px) + Sqr(py - Points[i].py));
    Idx[i] := i;
  end;

  for i := 0 to High(Dist) - 1 do
    for j := i + 1 to High(Dist) do
      if Dist[j] < Dist[i] then
      begin
        tmpD := Dist[i]; Dist[i] := Dist[j]; Dist[j] := tmpD;
        tmpI := Idx[i]; Idx[i] := Idx[j]; Idx[j] := tmpI;
      end;

  p1 := Idx[0];
  p2 := Idx[1];
  p3 := -1;

  for i := 2 to High(Idx) do
  begin
    x1 := Points[p1].px; y1 := Points[p1].py;
    x2 := Points[p2].px; y2 := Points[p2].py;
    x3 := Points[Idx[i]].px; y3 := Points[Idx[i]].py;

    det := (y2 - y3)*(x1 - x3) + (x3 - x2)*(y1 - y3);
    if Abs(det) > 10.0 then
    begin
      p3 := Idx[i];
      Break;
    end;
  end;

  if p3 = -1 then p3 := Idx[2];

  x1 := Points[p1].px; y1 := Points[p1].py; gx1 := Points[p1].gx; gy1 := Points[p1].gy;
  x2 := Points[p2].px; y2 := Points[p2].py; gx2 := Points[p2].gx; gy2 := Points[p2].gy;
  x3 := Points[p3].px; y3 := Points[p3].py; gx3 := Points[p3].gx; gy3 := Points[p3].gy;

  det := (y2 - y3)*(x1 - x3) + (x3 - x2)*(y1 - y3);
  if Abs(det) < 0.001 then Exit;

  L1 := ((y2 - y3)*(px - x3) + (x3 - x2)*(py - y3)) / det;
  L2 := ((y3 - y1)*(px - x3) + (x1 - x3)*(py - y3)) / det;
  L3 := 1.0 - L1 - L2;

  GeoX := L1 * gx1 + L2 * gx2 + L3 * gx3;
  GeoY := L1 * gy1 + L2 * gy2 + L3 * gy3;
end;



procedure TForm5.FormKeyPress(Sender: TObject; var Key: Char);
begin
  if (key='+') then
    begin
      zoom:=zoom*1.1;
      Image1.Width:=Round(2133*zoom);
      Image1.Height:=Round(2679*zoom);
      Image1.Picture.Bitmap.Height := Round(2679*zoom);
      Image1.Picture.Bitmap.Width := Round(2133*zoom);
      WidthImage:=Round(2133*zoom);
      HightImage:=Round(2679*zoom);
      R.X :=  0 ;  R.Y := 0;
      R.Width := WidthImage;  R.Height := HightImage;
      Bitmap.Free;
      Bitmap:=TGPBitmap.Create(WidthImage,HightImage);
      graphicsGDIPlus:= TGPGraphics.Create(Bitmap);
      GraphicsGDIPlus.SetInterpolationMode(InterpolationModeHighQualityBicubic);
      graphicsGDIPlus.drawImage(Image,R);
      graphicsGDIPlus.Free;
      graphicsGDIPlus:= TGPGraphics.Create(Image1.Canvas.Handle);
      cBitmap.Free;
      cBitmap:= TGPCachedBitmap.Create(BitMap, graphicsGDIPlus);
      graphicsGDIPlus.DrawCachedBitmap(cBitMap,0,0);
      graphicsGDIPlus.Free;
      LPaint;
    end;

  if (key='-') then
    begin
      zoom:=zoom/1.1;
      Image1.Width:=Round(2133*zoom);
      Image1.Height:=Round(2679*zoom);
      Image1.Picture.Bitmap.Height := Round(2679*zoom);
      Image1.Picture.Bitmap.Width := Round(2133*zoom);

      WidthImage:=Round(2133*zoom);
      HightImage:=Round(2679*zoom);
      R.X :=  0 ;  R.Y := 0;
      R.Width := WidthImage;  R.Height := HightImage;
      Bitmap.Free;
      Bitmap:=TGPBitmap.Create(WidthImage,HightImage);
      graphicsGDIPlus:= TGPGraphics.Create(Bitmap);
      graphicsGDIPlus.drawImage(Image,R);
      graphicsGDIPlus.Free;

      graphicsGDIPlus:= TGPGraphics.Create(Image1.Canvas.Handle);
      cBitmap.Free;
      cBitmap:= TGPCachedBitmap.Create(BitMap, graphicsGDIPlus);
      graphicsGDIPlus.DrawCachedBitmap(cBitMap,0,0);
      graphicsGDIPlus.Free;
      LPaint;
    end;
end;

