  text: string;
  RealGX, RealGY: Double;
  UserX, UserY, ErrorDist: Double;
begin
  if Edit3.Text = '8' then
    text := 'Номер зоны определен верно.'
  else
    text := 'Номер зоны определен неверно.';

  RealGX := 6320 - ((FixFx - x1) * xx2 / det + (FixFy - y1) * yy2 / det);
  RealGY := 8380 + ((FixFx - x1) * xx1 / det + (FixFy - y1) * yy1 / det);

  try
    UserX := StrToFloat(Edit1.Text) / 1000.0;
    UserY := StrToFloat(Edit2.Text) / 1000.0;
  except
    MessageBox(Self.Handle,
      'Пожалуйста, введите корректные числовые значения в поля X и Y.',
      'Ошибка ввода', MB_OK or MB_ICONWARNING);
    Exit;
  end;

  ErrorDist := Sqrt(Sqr(UserX - RealGX) + Sqr(UserY - RealGY));

  MessageBox(Self.Handle,
    PChar('Ошибка составляет ' +
      FloatToStrF(ErrorDist, ffFixed, 8, 3) + ' км. ' + text + #13 +
      '                              ПОЗОВИТЕ ПРЕПОДАВАТЕЛЯ'),
    PChar('Результаты'),
    MB_OK or MB_ICONINFORMATION or MB_TOPMOST or MB_TASKMODAL);
end;

procedure TFormcoords100k.Button1Click(Sender: TObject);
var
  dx : integer;
  dy : integer;
  px : integer;
  py : integer;
  kx, ky : real;
  dolgota : real;
  shirota : real;
  delta_shirota, delta_dolgota : real;
begin
  if FixZ = '' then
  begin
    MessageBox(Self.Handle,
      'Ты конечно молодец...Но флажок установить-то надо)))',
      'Внимание', MB_OK or MB_ICONWARNING);
    Exit;
  end;

  try
    shirota := StrToFloat(Edit4.Text)*3600 + StrToFloat(Edit5.Text)*60 + StrToFloat(Edit6.Text);
    dolgota := StrToFloat(Edit7.Text)*3600 + StrToFloat(Edit8.Text)*60 + StrToFloat(Edit9.Text);
  except
    MessageBox(Self.Handle,
      'Пожалуйста, введите корректные значения градусов, минут и секунд.',
      'Ошибка ввода', MB_OK or MB_ICONWARNING);
    Exit;
  end;

  dx := 120;
  dy := 134;

  px := fixfx - dx;
  py := fixfy - dy;

  kx := 1800 / 1795;
  ky := 3600 / 2189;

  delta_shirota := shirota - (56*3600+40*60+(2189-py)*ky) + 2400*(2189-py)/2189;
  delta_dolgota := dolgota - (43*3600+px*kx);

  MessageBox(Self.Handle,
    PChar('Ошибка по широте: ' + FloatToStr(RoundTo(delta_shirota, -1)) +
          '" ; по долготе: ' + FloatToStr(RoundTo(delta_dolgota, -1)) + '".'),
    'Результат', MB_OK or MB_ICONINFORMATION);
end;

