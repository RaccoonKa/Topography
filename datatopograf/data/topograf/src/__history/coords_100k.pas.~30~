procedure TFormcoords100k.FormKeyPress(Sender: TObject; var Key: Char);
var
  NewZoom: Real;
  NewW, NewH: Integer;
  NewBitmap: TGPBitmap;
  NewCached: TGPCachedBitmap;
  NewGraphics: TGPGraphics;
begin
  if FZooming then Exit;
  FZooming := True;
  try
    if (key = '+') then
      NewZoom := zoom * 1.1
    else if (key = '-') then
      NewZoom := zoom / 1.1
    else
      Exit;

    NewW := Round(2043 * NewZoom);
    NewH := Round(2566 * NewZoom);

    NewBitmap := TGPBitmap.Create(NewW, NewH);
    try
      NewGraphics := TGPGraphics.Create(NewBitmap);
      try
        NewGraphics.SetInterpolationMode(InterpolationModeHighQualityBicubic);
        NewGraphics.DrawImage(Image, MakeRect(0, 0, NewW, NewH));
      finally
        NewGraphics.Free;
      end;

      NewCached := TGPCachedBitmap.Create(NewBitmap, TGPGraphics.Create(Image1.Canvas.Handle));
    except
      NewBitmap.Free;
      raise;
    end;

    cBitmap.Free;
    cBitmap := NewCached;

    Bitmap.Free;
    Bitmap := NewBitmap;

    zoom := NewZoom;
    Image1.Width := NewW;
    Image1.Height := NewH;
    Image1.Picture.Bitmap.Width := NewW;
    Image1.Picture.Bitmap.Height := NewH;
    WidthImage := NewW;
    HightImage := NewH;
    R.X := 0; R.Y := 0; R.Width := NewW; R.Height := NewH;

    LPaint;
  finally
    FZooming := False;
  end;
end;

