procedure TFormcoords100k.Image1MouseDown(Sender: TObject; Button: TMouseButton;
Shift: TShiftState; X, Y: Integer);
begin
  ScrollingDownY:=Y;
  ScrollingDownPositionY:=ScrollBox1.VertScrollBar.Position;
  ScrollingDownX:=X;
  ScrollingDownPositionX:=ScrollBox1.HorzScrollBar.Position;
end;

procedure TFormcoords100k.Image1MouseMove(Sender: TObject; Shift: TShiftState; X,
  Y: Integer);
begin
  MouseX:=x;
  MouseY:=y;
  if (WhatDraw <> '0') or FixL then
    Lpaint;
  if ssLeft in Shift then
    begin
      ScrollBox1.VertScrollBar.Position:=ScrollingDownPositionY+(ScrollingDownY-Y);
      ScrollingDownPositionY:= ScrollBox1.VertScrollBar.Position;
      ScrollBox1.HorzScrollBar.Position:=ScrollingDownPositionX+(ScrollingDownX-X);
      ScrollingDownPositionX:= ScrollBox1.HorzScrollBar.Position;
      ScrollBox1.Update;
      Scrolling:=True;
    end;
end;


procedure TFormcoords100k.Image1MouseUp(Sender: TObject; Button: TMouseButton;
Shift: TShiftState; X, Y: Integer);
begin
  if not Scrolling then
  begin
    if (WhatDraw='Z1') or (WhatDraw='Z2') or (WhatDraw='Z3') or (WhatDraw='Z4') then
      begin
        Image1.Cursor:=crDefault;
        FixZ:=whatdraw;
        FixFX:=Round(MouseX/zoom);
        FixFY:=Round(MouseY/zoom);
        BTest.Enabled:=True;
        Button1.Enabled:=True;
        WhatDraw:='0';
        LPaint;
      end;
    if WhatDraw='L' then
      begin
        Image1.Cursor:=crDefault;
        FixL:=true;
        FixLx:=Round(MouseX/zoom);
        FixLy:=Round(MouseY/zoom);
        FixSpin:=Spin;
        WhatDraw:='0'
      end;
    if FixL and (Button=mbRight) then
      begin
        whatDraw:='L';
        FixL:=false;
        Lpaint;
      end;
  end
    else Scrolling:=False;
end;

Procedure TFormcoords100k.LPaint;
var i:integer;
begin
  T1:=now;
  graphicsGDIPlus:= TGPGraphics.Create(Image1.Canvas.Handle);
  GraphicsGDIPlus.SetInterpolationMode(InterpolationModeHighQualityBicubic);
  R.X := 0 ;  R.Y :=0;
  R.Width := 2043*zoom;  R.Height := 2566*zoom;
  graphicsGDIPlus.SetSmoothingMode(SmoothingModeAntiAlias);
  graphicsGDIPlus.DrawCachedBitmap(cBitMap,0,0);

  if whatDraw='Z1' then
    graphicsGDIPlus.DrawImage(znak1,MouseX-31,MouseY-75,75,75);
  if FixZ='Z1' then
    graphicsGDIPlus.DrawImage(znak1,FixFX*zoom-31,FixFy*zoom-75,75,75);
  if whatDraw='Z2' then
    graphicsGDIPlus.DrawImage(znak2,MouseX-36,MouseY-63,75,75);
  if FixZ='Z2' then
    graphicsGDIPlus.DrawImage(znak2,FixFX*zoom-36,FixFy*zoom-63,75,75);
  if whatDraw='Z3' then
    graphicsGDIPlus.DrawImage(znak3,MouseX-75,MouseY-38,75,75);
  if FixZ='Z3' then
    graphicsGDIPlus.DrawImage(znak3,FixFX*zoom-75,FixFy*zoom-38,75,75);
  if whatDraw='Z4' then
    graphicsGDIPlus.DrawImage(znak4,MouseX-37,MouseY-62,75,75);
  if FixZ='Z4' then
    graphicsGDIPlus.DrawImage(znak4,FixFX*zoom-37,FixFy*zoom-62,75,75);
  if  fixL  then
  begin
    graphicsGDIPlus.TranslateTransform(FixLX*zoom,FixLY*zoom);
    graphicsGDIPlus.ScaleTransform(zoom*Lzoom,zoom*Lzoom);
    graphicsGDIPlus.RotateTransform(-Fixspin);
    path := TGPGraphicsPath.Create;
    SolidBrush := TGPSolidBrush.Create(MakeColor(200,255, 255, 255));
    path.Reset;
    path.StartFigure();
    path.AddLine(-70,-40,150,-40);
    path.addLine(150,-40,-70,100);
    path.addLine(-70,100,-70,-40);
    path.AddLine(-40,-10,60,-10);
    path.addLine(60,-10,-40,50);
    path.addLine(-40,50,-40,-10);
    path.CloseFigure();
    graphicsGDIPlus.FillPath(SolidBrush, path);
    SolidBrush.Free;

    graphicsGDIPlus.DrawLine(pen,-70,-40,150,-40);
    graphicsGDIPlus.DrawLine(pen,150,-40,-70,100);
    graphicsGDIPlus.DrawLine(pen,-70,100,-70,-40);
    graphicsGDIPlus.DrawLine(pen,-40,-10,60,-10);
    graphicsGDIPlus.DrawLine(pen,60,-10,-40,50);
    graphicsGDIPlus.DrawLine(pen,-40,50,-40,-10);

    for i:=1 to 100 do
    begin
      if i mod 5 = 0 then
        graphicsGDIPlus.DrawLine(pen,i*2-70,-40,i*2-70,-33)
      else
        graphicsGDIPlus.DrawLine(pen,i*2-70,-40,i*2-70,-35);
  end;

  FontFamily := TGPFontFamily.Create('Times New Roman');
  Font := TGPFont.Create(FontFamily, 9, FontStyleRegular, UnitPixel);
  SolidBrush := TGPSolidBrush.Create(MakeColor(255,0, 0, 0));
  for i:=1 to 9 do
    begin
      graphicsGDIPlus.SetTextRenderingHint(TextRenderingHintAntiAlias);
      graphicsGDIPlus.DrawString(inttostr(i), -1, Font, MakePoint(i*20-74, -33.0), solidBrush);
    end;
  graphicsGDIPlus.RotateTransform(+Fixspin);
  graphicsGDIPlus.ScaleTransform(1/(zoom*Lzoom),1/(zoom*Lzoom));
  graphicsGDIPlus.TranslateTransform(-FixLX*zoom,-FixLY*zoom);
  end;


  if (whatDraw='L')  then
    begin
      graphicsGDIPlus.TranslateTransform(Mousex,MouseY);
      graphicsGDIPlus.ScaleTransform(zoom*Lzoom,zoom*Lzoom);
      graphicsGDIPlus.RotateTransform(-spin);
      path := TGPGraphicsPath.Create;
      SolidBrush := TGPSolidBrush.Create(MakeColor(200,255, 255, 255));
      path.Reset;
      path.StartFigure();
      path.AddLine(-70,-40,150,-40);
      path.addLine(150,-40,-70,100);
      path.addLine(-70,100,-70,-40);
      path.AddLine(-40,-10,60,-10);
      path.addLine(60,-10,-40,50);
      path.addLine(-40,50,-40,-10);
      path.CloseFigure();
      graphicsGDIPlus.FillPath(SolidBrush, path);
      SolidBrush.Free;

      graphicsGDIPlus.DrawLine(pen,-70,-40,150,-40);
      graphicsGDIPlus.DrawLine(pen,150,-40,-70,100);
      graphicsGDIPlus.DrawLine(pen,-70,100,-70,-40);
      graphicsGDIPlus.DrawLine(pen,-40,-10,60,-10);
      graphicsGDIPlus.DrawLine(pen,60,-10,-40,50);
      graphicsGDIPlus.DrawLine(pen,-40,50,-40,-10);

      for i:=1 to 100 do
      begin
        if i mod 5 = 0 then
          graphicsGDIPlus.DrawLine(pen,i*2-70,-40,i*2-70,-33)
        else
          graphicsGDIPlus.DrawLine(pen,i*2-70,-40,i*2-70,-35);
      end;

      FontFamily := TGPFontFamily.Create('Times New Roman');
      Font := TGPFont.Create(FontFamily, 9, FontStyleRegular, UnitPixel);
      SolidBrush := TGPSolidBrush.Create(MakeColor(255,0, 0, 0));
      for i:=1 to 9 do
      begin
        graphicsGDIPlus.SetTextRenderingHint(TextRenderingHintAntiAlias);
        graphicsGDIPlus.DrawString(inttostr(i), -1, Font, MakePoint(i*20-74, -33.0), solidBrush);
      end;
  end;


  Image1.Repaint;

  T2:=now;
  DecodeTime(T2-T1,h,m,s,ms);
  Caption:=(IntTostr(s) +':'+ IntTostr(ms)+'  '+IntToStr(Mousex)+'x'+IntToStr(Mousey)+
    '  '+FloatToStrF((8380+((Mousex/zoom-x1)*xx1/det+(Mousey/zoom-y1)*yy1/det)), ffFixed, 8, 1)+'x'+
  FloatToStrF((6320-((Mousex/zoom-x1)*xx2/det+(Mousey/zoom-y1)*yy2/det)), ffFixed, 8, 1)+
    '   '+ FloatToStrF(ScrollBox1.VertScrollBar.Range, ffFixed, 8, 1)+' '+
  FloatToStrF(ScrollBox1.VertScrollBar.Position+ScrollBox1.ClientHeight, ffFixed, 8, 1));
end;

