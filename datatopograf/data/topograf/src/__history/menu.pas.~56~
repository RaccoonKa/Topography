const
  ButtonWidth = 300;
  ButtonHeight = 60;
  VerticalGap = 20;
  MapVerticalGap = 60;

procedure TMenuSpeedButton.Paint;
var
  graphics: TGPGraphics;
  path, borderPath: TGPGraphicsPath;
  brush: TGPSolidBrush;
  pen: TGPPen;
  rect: TGPRectF;
  radius: Single;
begin
  inherited Paint;
  graphics := TGPGraphics.Create(Canvas.Handle);
  try
    graphics.SetSmoothingMode(SmoothingModeAntiAlias);
    graphics.SetPixelOffsetMode(PixelOffsetModeHighQuality);

    radius := 20;

    path := TGPGraphicsPath.Create;
    try
      rect.X := 0;
      rect.Y := 0;
      rect.Width := Width;
      rect.Height := Height;
      path.AddRectangle(rect);

      path.AddArc(rect.X, rect.Y, radius * 2, radius * 2, 180, 90);
      path.AddArc(rect.X + rect.Width - radius * 2, rect.Y, radius * 2, radius * 2, 270, 90);
      path.AddArc(rect.X + rect.Width - radius * 2, rect.Y + rect.Height - radius * 2, radius * 2, radius * 2, 0, 90);
      path.AddArc(rect.X, rect.Y + rect.Height - radius * 2, radius * 2, radius * 2, 90, 90);
      path.CloseFigure();

      brush := TGPSolidBrush.Create(MakeColor(255, 0, 0, 0));
      try
        graphics.FillPath(brush, path);
      finally
        brush.Free;
      end;
    finally
      path.Free;
    end;

    pen := TGPPen.Create(MakeColor(255, 255, 215, 0), 2);
    borderPath := TGPGraphicsPath.Create;
    try
      rect.X := 1;
      rect.Y := 1;
      rect.Width := Width - 2;
      rect.Height := Height - 2;

      borderPath.AddArc(rect.X, rect.Y, radius * 2, radius * 2, 180, 90);
      borderPath.AddArc(rect.X + rect.Width - radius * 2, rect.Y, radius * 2, radius * 2, 270, 90);
      borderPath.AddArc(rect.X + rect.Width - radius * 2, rect.Y + rect.Height - radius * 2, radius * 2, radius * 2, 0, 90);
      borderPath.AddArc(rect.X, rect.Y + rect.Height - radius * 2, radius * 2, radius * 2, 90, 90);
      borderPath.CloseFigure();

      graphics.DrawPath(pen, borderPath);
    finally
      borderPath.Free;
      pen.Free;
    end;
  finally
    graphics.Free;
  end;
end;

procedure TFormmenu.FormCreate(Sender: TObject);
begin
  Self.Caption := 'Топограф';
  BorderStyle := bsNone;
  Color := clBlack;
  WindowState := wsMaximized;
  DoubleBuffered := True;

  if FileExists('..\data\topograf\assets\earth_maps\earth.png') then
    FFonImage := TGPImage.Create('..\data\topograf\assets\earth_maps\earth.png')
  else
    FFonImage := nil;

  if FileExists('..\data\topograf\assets\decorations/logo_vuc.jpg') then
    FLogoImage := TGPImage.Create('..\data\topograf\assets\decorations/logo_vuc.jpg')
  else
    FLogoImage := nil;

  Self.OnPaint := FormPaint;
  Self.OnDestroy := FormDestroy;

  CreateMainMenu;
  CreateMapMenu;

  Label1.Caption := 'Масштаб 1:100000';
  Label1.Font.Size := 12;
  Label1.Font.Color := clWhite;
  Label1.Visible := False;

  Label2.Caption := 'Масштаб 1:25000';
  Label2.Font.Size := 12;
  Label2.Font.Color := clWhite;
  Label2.Visible := False;

  Label3.Caption := 'Масштаб 1:50000';
  Label3.Font.Size := 12;
  Label3.Font.Color := clWhite;
  Label3.Visible := False;

  LabelCredits.Font.Color := $00D7FF;
  LabelCredits.Font.Size := 0;
  LabelCredits.Font.Height := -17;
  LabelCredits.Font.Name := 'Segoe UI';
  LabelCredits.Font.Style := [fsBold];
  LabelCredits.Alignment := taRightJustify;
  LabelCredits.Caption := 'Выполнили:' + sLineBreak +
                          'Кравчук Светозар Кириллович' + sLineBreak +
                          'Семиков Даниил Александрович' + sLineBreak +
                          '' + sLineBreak +
                          'Научный руководитель:' + sLineBreak +
                          'Рак Евгений Николаевич';
  LabelCredits.Visible := False;

  ShowMainMenu;
end;

procedure TFormmenu.FormDestroy(Sender: TObject);
begin
  FFonImage.Free;
  FLogoImage.Free;
end;

procedure TFormmenu.FormPaint(Sender: TObject);
const
  VisibilityRatio = 0.7;
var
  graphics: TGPGraphics;
  imgW, imgH: Integer;
  targetH, targetW: Integer;
  destRect1, destRect2: TGPRectF;
begin
  if (FFonImage = nil) or (not FInMapMenu) then
    Exit;

  graphics := TGPGraphics.Create(Canvas.Handle);
  try
    graphics.SetInterpolationMode(InterpolationModeHighQualityBicubic);
    graphics.SetSmoothingMode(SmoothingModeAntiAlias);
    graphics.SetPixelOffsetMode(PixelOffsetModeHighQuality);

    imgW := FFonImage.GetWidth;
    imgH := FFonImage.GetHeight;

    targetH := Round(ClientHeight * 1);
    targetW := Round(targetH * imgW / imgH);

    destRect1.Width := targetW;
    destRect1.Height := targetH;
    destRect1.X := -Round(targetW * (1 - VisibilityRatio));
    destRect1.Y := ClientHeight - Round(targetH * VisibilityRatio);

    destRect2.Width := targetW;
    destRect2.Height := targetH;
    destRect2.X := ClientWidth - Round(targetW * VisibilityRatio);
    destRect2.Y := -Round(targetH * (1 - VisibilityRatio));

    graphics.DrawImage(FFonImage, destRect1, 0, 0, imgW, imgH, UnitPixel);
    graphics.DrawImage(FFonImage, destRect2, 0, 0, imgW, imgH, UnitPixel);
  finally
    graphics.Free;
  end;
end;

procedure TFormmenu.ImageLogoPaint(Sender: TObject);
var
  graphics: TGPGraphics;
  destRect: TGPRectF;
  imgWidth, imgHeight: Integer;
  w, h: Integer;
begin
  if FLogoImage = nil then Exit;

  graphics := TGPGraphics.Create(ImageLogo.Canvas.Handle);
  try
    graphics.SetInterpolationMode(InterpolationModeHighQualityBicubic);
    graphics.SetSmoothingMode(SmoothingModeAntiAlias);
    graphics.SetPixelOffsetMode(PixelOffsetModeHighQuality);

    imgWidth := FLogoImage.GetWidth;
    imgHeight := FLogoImage.GetHeight;

    if (ImageLogo.Width / ImageLogo.Height) > (imgWidth / imgHeight) then
    begin
      h := ImageLogo.Height;
      w := Round(h * imgWidth / imgHeight);
    end
    else
    begin
      w := ImageLogo.Width;
      h := Round(w * imgHeight / imgWidth);
    end;

    destRect.X := (ImageLogo.Width - w) / 2;
    destRect.Y := (ImageLogo.Height - h) / 2;
    destRect.Width := w;
    destRect.Height := h;

    graphics.DrawImage(FLogoImage, destRect, 0, 0, imgWidth, imgHeight, UnitPixel);
  finally
    graphics.Free;
  end;
end;

procedure TFormmenu.CreateMainMenu;
const
  Captions: array[0..3] of string = ('Карты', 'Обучение', 'О программе', 'Выход');
var
  events: array[0..3] of TNotifyEvent;
  i: Integer;
begin
  events[0] := OnMapsClick;
  events[1] := OnLearningClick;
  events[2] := OnAboutClick;
  events[3] := OnExitClick;

  for i := 0 to 3 do
  begin
    FMainButtons[i] := TMenuSpeedButton.Create(Self);
    with FMainButtons[i] do
    begin
      Parent := Self;
      Caption := Captions[i];
      Flat := True;
      Font.Color := $00D7FF;
      Font.Size := 14;
      Font.Name := 'Segoe UI';
      Font.Style := [fsBold];
      Cursor := crHandPoint;
      Width := ButtonWidth;
      Height := ButtonHeight;
      OnClick := events[i];
      Visible := True;
    end;
  end;
end;

procedure TFormmenu.CreateMapMenu;
const
  Captions: array[0..3] of string = ('Чкаловск (1986 г.)', 'СНОВ (1991 г.)', 'СНОВ (1966 г.)', 'Назад');
var
  events: array[0..3] of TNotifyEvent;
  i: Integer;
begin
  events[0] := OnChkalovskClick;
  events[1] := OnSnov1991Click;
  events[2] := OnSnov1966Click;
  events[3] := OnMapMenuBack;

  for i := 0 to 3 do
  begin
    FMapButtons[i] := TMenuSpeedButton.Create(Self);
    with FMapButtons[i] do
    begin
      Parent := Self;
      Caption := Captions[i];
      Flat := True;
      Font.Color := $00D7FF;
      Font.Size := 14;
      Font.Name := 'Segoe UI';
      Font.Style := [fsBold];
      Cursor := crHandPoint;
      Width := ButtonWidth;
      Height := ButtonHeight;
      OnClick := events[i];
      Visible := False;
    end;
  end;
end;

procedure TFormmenu.ShowMainMenu;
var
  i: Integer;
begin
  for i := 0 to 3 do
    FMainButtons[i].Visible := True;
  for i := 0 to 3 do
    FMapButtons[i].Visible := False;
  Label1.Visible := False;
  Label2.Visible := False;
  Label3.Visible := False;
  LabelCredits.Visible := True;
  FInMapMenu := False;
  Self.Invalidate;
  FormResize(Self);
  ImageLogo.Visible := True;
end;

procedure TFormmenu.ShowMapMenu;
var
  i: Integer;
begin
  for i := 0 to 3 do
    FMainButtons[i].Visible := False;
  for i := 0 to 3 do
    FMapButtons[i].Visible := True;
  Label1.Visible := True;
  Label2.Visible := True;
  Label3.Visible := True;
  LabelCredits.Visible := False;
  FInMapMenu := True;
  Self.Invalidate;
  FormResize(Self);
  ImageLogo.Visible := False;
end;

procedure TFormmenu.OnMapsClick(Sender: TObject);
begin
  ShowMapMenu;
end;

procedure TFormmenu.OnMapMenuBack(Sender: TObject);
begin
  ShowMainMenu;
end;

procedure TFormmenu.OnLearningClick(Sender: TObject);
begin
  if Formtraining = nil then
    Application.CreateForm(TFormtraining, Formtraining);
  Formtraining.Show;
end;

procedure TFormmenu.OnAboutClick(Sender: TObject);
begin
  if Formprogramm = nil then
    Application.CreateForm(TFormprogramm, Formprogramm);
  Formprogramm.Show;
end;

procedure TFormmenu.OnExitClick(Sender: TObject);
begin
  Application.Terminate;
end;

procedure TFormmenu.OnChkalovskClick(Sender: TObject);
var
  F: TFormcoords100k;
  i: Integer;
begin
  if Formprogramm = nil then
    Application.CreateForm(TFormprogramm, Formprogramm);
  if Assigned(Formtraining) then Formtraining.Hide;
  if Assigned(Formprogramm) then Formprogramm.Hide;

  for i := 0 to 3 do
    FMapButtons[i].Enabled := False;

  F := TFormcoords100k.Create(Self);
  try
    F.PopupParent := Self;
    F.PopupMode := pmExplicit;
    Self.FormStyle := fsStayOnTop;
    F.ShowModal;
  finally
    if Assigned(Formtraining) then Formtraining.Hide;
    if Assigned(Formprogramm) then Formprogramm.Hide;
    F.Free;
    Self.FormStyle := fsNormal;
    Application.BringToFront;
    SetForegroundWindow(Self.Handle);
    Application.ProcessMessages;

    for i := 0 to 3 do
      FMapButtons[i].Enabled := True;
  end;
end;

