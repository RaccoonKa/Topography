procedure TForm5.BTestClick(Sender: TObject);
var
  i, j, q: integer;
  dist, angle, diff: double;
  R: array[1..4] of array[1..6] of string;
  U: array[1..4] of double;
  dat: array[1..4] of double;
begin
  // ЗАЩИТА ОТ БАГОВ: Проверка, что точки установлены и не совпадают
  dist := sqrt(sqr(FixFX2 - FixFX) + sqr(FixFY2 - FixFY));
  if dist = 0 then
  begin
    ShowMessage('Сначала укажите две разные точки на карте!');
    Exit;
  end;

  if FixFX2 >= FixFX then
    angle := 180 / Pi * ArcCos((FixFY - FixFY2) / dist)
  else
    angle := 360 - 180 / Pi * ArcCos((FixFY - FixFY2) / dist);

  dat[1] := angle;
  if dat[1] >= 360 then dat[1] := dat[1] - 360;

  // Сближение (gamma) = Западное 2°24' = -2.4 градуса
  dat[2] := dat[1] - 2.4;
  if dat[2] < 0 then dat[2] := dat[2] + 360;
  if dat[2] >= 360 then dat[2] := dat[2] - 360;

  // 3. Магнитный азимут (dat[3]). Формула: Am = Истинный азимут - Склонение
  dat[3] := dat[2] - 6.25;
  if dat[3] < 0 then dat[3] := dat[3] + 360;
  if dat[3] >= 360 then dat[3] := dat[3] - 360;

  // Базовый год изменен на 1966. Изменение: +2 минуты (0.0333 градуса) в год.
  if Length(ComboBox1.Text) <> 0 then
    dat[4] := (StrToInt(ComboBox2.Text) - 1966) * 2 / 60
  else
  begin
    ComboBox2.Text := '2015'; // Год по умолчанию для расчетов
    dat[4] := (2015 - 1966) * 2 / 60;
  end;

  // Считывание данных из полей (Edit)
  R[1][1] := Edit1.Text;  R[1][2] := Edit9.Text;
  R[2][1] := Edit2.Text;  R[2][2] := Edit10.Text;
  R[3][1] := Edit3.Text;  R[3][2] := Edit11.Text;
  R[4][1] := Edit4.Text;  R[4][2] := Edit5.Text;

  for i := 1 to 4 do
  begin
    if Length(Trim(R[i][1])) = 0 then R[i][1] := '0';
    if Length(Trim(R[i][2])) = 0 then R[i][2] := '0';
    U[i] := StrToFloat(R[i][1]) + StrToFloat(R[i][2]) / 60;
  end;

  // Сравнение углов (с учетом кругового перехода 360 градусов)
  for i := 1 to 3 do
  begin
    diff := Abs(U[i] - dat[i]);
    if diff > 180 then diff := 360 - diff;

    R[i][3] := IntToStr(Trunc(diff));
    R[i][4] := IntToStr(Round((diff - Trunc(diff)) * 60));
  end;

  // Сравнение для магнитного изменения (dat[4])
  if ComboBox1.ItemIndex = 0 then q := 1
  else if ComboBox1.ItemIndex = 1 then q := -1
  else q := 0;

  diff := Abs(q * U[4] - dat[4]);
  R[4][3] := IntToStr(Trunc(diff));
  R[4][4] := IntToStr(Round((diff - Trunc(diff)) * 60));

  // Форматирование вывода
  for i := 1 to 4 do
  begin
    for j := 1 to (6 - Length(TrimLeft(R[i][3]))) do R[i][3] := '  ' + R[i][3];
    for j := 1 to (2 - Length(TrimLeft(R[i][4]))) do R[i][4] := '  ' + R[i][4];
    for j := 1 to (3 - Length(TrimLeft(R[i][1]))) do R[i][1] := '  ' + R[i][1];
    for j := 1 to (2 - Length(TrimLeft(R[i][2]))) do R[i][2] := '  ' + R[i][2];
  end;

  // Проверка результатов
  for i := 1 to 3 do
  begin
    if (StrToFloat(Trim(R[i][3])) + StrToFloat(Trim(R[i][4])) / 60) <= 1.2 then
      R[i][5] := '✓' else R[i][5] := '✕';
    for j := 1 to 12 do R[i][5] := ' ' + R[i][5];
  end;

  if (StrToFloat(Trim(R[4][3])) + StrToFloat(Trim(R[4][4])) / 60) <= 0.02 then
    R[4][5] := '✓' else R[4][5] := '✕';
  for j := 1 to 12 do R[4][5] := ' ' + R[4][5];

  ShowMessage('Величина                                     Значение    Ошибка    Результат' + #13#10 +
