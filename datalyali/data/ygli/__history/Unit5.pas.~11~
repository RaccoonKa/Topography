procedure TForm5.FormShow(Sender: TObject);
begin
  zoom := 1;
  Lzoom := 2.93;
  FixL := False;
  pen := TGPPen.Create(MakeColor(255, 255, 0, 0), 2);

  // Загрузка графики кнопок
  Bexit.Glyph.LoadFromFile('..\data\ygli\green/Btnexitgreen.bmp');
  SpeedButton1.Glyph.LoadFromFile('..\data\ygli\green/Btn2New1.bmp');
  Bhide.Glyph.LoadFromFile('..\data\ygli\green/Bhide1.bmp');
  Bznak1.Glyph.LoadFromFile('..\data\ygli\green/Flag11.bmp');
  Bznak2.Glyph.LoadFromFile('..\data\ygli\green/Flag21.bmp');
  Bznak4.Glyph.LoadFromFile('..\data\ygli\green/Flag41.bmp');
  Panel1.Color := RGB(31, 21, 5);
  Panel3.Color := RGB(31, 21, 5);
  Image1.Cursor := crHandPoint;

  // Загрузка изображения новой карты (1:25000)
  Image := TGPBitmap.Create('..\data\ygli\MAP25k.jpg');
  if Image.GetLastStatus <> Ok then
  begin
    ShowMessage('Ошибка загрузки изображения карты!' + sLineBreak +
                'Убедитесь, что файл MAP25k.jpg находится в папке ..\data\ygli\');
    Exit;
  end;

  // Размеры новой карты (замените на реальные!)
  WidthImage := Round(3000 * zoom);
  HightImage := Round(4000 * zoom);

  R.X := 0; R.Y := 0;
  R.Width := WidthImage; R.Height := HightImage;
  bitmap := TGPBitmap.Create(WidthImage, HightImage);
  graphicsGDIPlus := TGPGraphics.Create(bitmap);
  graphicsGDIPlus.DrawImage(Image, R);
  graphicsGDIPlus.Free;

  graphicsGDIPlus := TGPGraphics.Create(Image1.Canvas.Handle);
  cBitmap := TGPCachedBitmap.Create(bitmap, graphicsGDIPlus);
  graphicsGDIPlus.DrawCachedBitmap(cBitmap, 0, 0);
  graphicsGDIPlus.Free;

  // Устанавливаем размер Image1 в соответствии с zoom
  Image1.Width := Round(3000 * zoom);
  Image1.Height := Round(4000 * zoom);

  // Координаты углов карты в пикселях (примерные, замените на реальные)
  X1 := 100; Y1 := 100;
  X2 := 500; Y2 := 100;
  X3 := 500; Y3 := 500;
  X4 := 100; Y4 := 500;

  // Расчёт параметров преобразования
  yy2 := (x2 - x1 + x3 - x4) / 16;
  yy1 := (y2 - y1 + y3 - y4) / 16;
  xx2 := (x4 - x1 + x3 - x2) / 16;
  xx1 := (y4 - y1 + y3 - y2) / 16;
  Det := xx1 * yy2 - xx2 * yy1;

  // Загрузка общих значков
  znak1 := TGPImage.Create('..\data\ygli\flag1.2.png');
  znak2 := TGPImage.Create('..\data\ygli\flag1.1.png');
  znak3 := TGPImage.Create('..\data\ygli\flag1.1.2.png');
  znak4 := TGPImage.Create('..\data\ygli\flag4.png');
  Transportir := TGPImage.Create('..\data\ygli\Transportir.png');

  ComboBox1.Items.LoadFromFile('..\data\ygli\УвелУмен.txt');
  ComboBox2.Items.LoadFromFile('..\data\ygli\Года.txt');

  Bexit.SetFocus;

  SpeedButton2.Glyph.LoadFromFile('..\data\ygli\green\11.bmp');
  SpeedButton3.Glyph.LoadFromFile('..\data\ygli\green\31.bmp');
end;

