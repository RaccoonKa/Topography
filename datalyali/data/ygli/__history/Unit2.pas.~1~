procedure TForm2.BTestClick(Sender: TObject);
var i,j,q:integer; text:string; a,d,m:double;//истинный, дир, магн
R:array[1..4] of array[1..6] of string;
U:array[1..4] of double;
dat:array[1..4] of double;
begin
//истинный              //СПРАВА
if FixFX2 >= FixFX then
  begin
  dat[2]:=0.16+180/3.1415*ArcCos((FixFY-FixFY2)/sqrt((FixFX2-FixFX)*(FixFX2-FixFX)+(FixFY2-FixFY)*(FixFY2-FixFY)));
  end;


  if FixFX2<FixFX then    ///СЛЕВА
  begin
  dat[2]:=0.16+180+180/3.1415*ArcCos((FixFY2-FixFY)/sqrt((FixFX-FixFX2)*(FixFX-FixFX2)+(FixFY2-FixFY)*(FixFY2-FixFY)));

  end;
  R[1][1]:=Edit1.Text;
  R[2][1]:=Edit2.Text;
  R[3][1]:=Edit3.Text;
  R[4][1]:=Edit4.Text;
  R[1][2]:=Edit9.Text;
  R[2][2]:=Edit10.Text;
  R[3][2]:=Edit11.Text;
  R[4][2]:=Edit5.Text;






//дирекционный
if dat[2]+1.467<360 then
dat[1]:=(dat[2]+1.467);
if dat[2]+1.467>=360 then
dat[1]:=(dat[2]+1.467)-360;
//магнитный
  if dat[2]-9.4>=0 then
     dat[3]:=(dat[2]-9.4);
  if dat[2]-9.4<0 then
     dat[3]:=(360-(dat[2]-9.4));
     if Length(ComboBox1.Text) <>0 then
  dat[4]:=(Strtoint(ComboBox2.Text)-1983)/60
  else
  begin
    ComboBox2.Text:='2015';
    dat[4]:=(2015-1983)/60;
  end;


     //ввод данных
for I := 1 to 4 do
begin
if Length(TrimLeft(R[i][1])) =0 then
 R[i][1]:=Inttostr(0);
if Length(TrimLeft(R[i][2])) = 0 then
 R[i][2]:=Inttostr(0);
 U[i]:=strtofloat(R[i][1])+strtofloat(R[i][2])/60;
end;

//сравнение
  for I := 1 to 4 do
  begin
  if Abs(U[i]-dat[i])<(360-Abs(U[i]-dat[i])) then
  begin
R[i][3]:=IntTostr(Trunc(Abs(U[i]-dat[i]))) ;
R[i][4]:=Inttostr(Trunc((Abs(U[i]-dat[i])-Strtofloat(R[i][3]))*60) );
  end
  else
  begin
R[i][3]:=IntTostr(Trunc(360-Abs(U[i]-dat[i])) ) ;
R[i][4]:=Inttostr(Trunc((360-Abs(U[i]-dat[i])-Strtofloat(R[i][3]))*60) );
  end;
 end;
  //ошибка для магн
  if ComboBox1.ItemIndex=0 then
     q:=1;
  if ComboBox1.ItemIndex=1 then
     q:=-1;
  if ComboBox1.ItemIndex=-1 then
     q:=0;
  if Abs(q*U[4]-dat[4])<(360-Abs(q*U[4]-dat[4])) then
  begin
R[4][3]:=IntTostr(Trunc(Abs(q*U[4]-dat[4])));
R[4][4]:=Inttostr(Round ((Abs(q*U[4]-dat[4])-Strtofloat(R[4][3]))*60) );
  end
  else
  begin
R[4][3]:=IntTostr(Trunc(360-Abs(q*U[4]-dat[4])) ) ;
R[4][4]:=Inttostr(Round ((360-Abs(q*U[4]-dat[4])-Strtofloat(R[4][3]))*60) );
  end;
    //
for I := 1 to 4 do
Begin
for j := 1 to (6-Length(TrimLeft(R[i][3])) )  do               //пробелы
  R[i][3]:='  '+R[i][3];
for j := 1 to (2-Length(TrimLeft(R[i][4])) )  do               //пробелы
  R[i][4]:='  '+R[i][4];
end;

 for i := 1 to 3 do
   begin
     if (Strtofloat(R[i][3])+Strtofloat(R[i][4])/60)<=1.2 then
      R[i][5]:='✓'
      else
      R[i][5]:='✕';

     for j := 1 to (12)  do               //пробелы
     R[i][5]:=' '+R[i][5];
    end;

    if (Strtofloat(R[4][3])+Strtofloat(R[4][4])/60)<=0.02 then       //для изиенения мер..
      R[i][5]:='✓'
      else
      R[i][5]:='✕';

     for j := 1 to (12)  do               //пробелы
     R[4][5]:=' '+R[4][5];
  ///первыче 2 числа
  for I := 1 to (3-Length(TrimLeft(R[1][1])) )  do               //градусы
  R[1][1]:=#32+#32+R[1][1];


  for I := 1 to (3-Length(TrimLeft(R[2][1])) )  do
  R[2][1]:='  '+R[2][1];


  for I := 1 to (3-Length(TrimLeft(R[3][1])) )  do
  R[3][1]:='  '+R[3][1];


  for I := 1 to (3-Length(TrimLeft(R[4][1])) )  do
  R[4][1]:='  '+R[4][1];



  for I := 1 to (2-Length(TrimLeft(R[1][2])) )  do               //минуты
  R[1][2]:='  '+R[1][2];


