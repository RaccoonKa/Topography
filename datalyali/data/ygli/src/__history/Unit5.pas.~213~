procedure TForm5.BTestClick(Sender: TObject);
var
  i, j, q: integer;
  text: string;
  a, d, m: double;
  R: array[1..4] of array[1..6] of string;
  U: array[1..4] of double;
  dat: array[1..4] of double;
begin
  if FixFX2 >= FixFX then
    dat[2] := 0.16 + 180 / 3.1415 * ArcCos((FixFY - FixFY2) / sqrt((FixFX2 - FixFX) * (FixFX2 - FixFX) + (FixFY2 - FixFY) * (FixFY2 - FixFY)))
  else
    dat[2] := 0.16 + 180 + 180 / 3.1415 * ArcCos((FixFY2 - FixFY) / sqrt((FixFX - FixFX2) * (FixFX - FixFX2) + (FixFY2 - FixFY) * (FixFY2 - FixFY)));

  R[1][1] := Edit1.Text;  R[1][2] := Edit9.Text;
  R[2][1] := Edit2.Text;  R[2][2] := Edit10.Text;
  R[3][1] := Edit3.Text;  R[3][2] := Edit11.Text;
  R[4][1] := Edit4.Text;  R[4][2] := Edit5.Text;

  if dat[2] + 2.4 < 360 then
    dat[1] := (dat[2] + 2.4)
  else
    dat[1] := (dat[2] + 2.4) - 360;

  if dat[2] - 6.2 >= 0 then
    dat[3] := (dat[2] - 6.2)
  else
    dat[3] := (360 - (dat[2] - 6.2));

  if Length(ComboBox2.Text) <> 0 then
    dat[4] := (StrToInt(ComboBox2.Text) - 1965) / 60
  else
  begin
    ComboBox2.Text := '2015';
    dat[4] := (2015 - 1965) / 60;
  end;

  for i := 1 to 4 do
  begin
    if Length(TrimLeft(R[i][1])) = 0 then R[i][1] := '0';
    if Length(TrimLeft(R[i][2])) = 0 then R[i][2] := '0';
    U[i] := StrToFloat(R[i][1]) + StrToFloat(R[i][2]) / 60;
  end;

  for i := 1 to 4 do
  begin
    if Abs(U[i] - dat[i]) < (360 - Abs(U[i] - dat[i])) then
    begin
      R[i][3] := IntToStr(Trunc(Abs(U[i] - dat[i])));
      R[i][4] := IntToStr(Trunc((Abs(U[i] - dat[i]) - StrToFloat(R[i][3])) * 60));
    end
    else
    begin
      R[i][3] := IntToStr(Trunc(360 - Abs(U[i] - dat[i])));
      R[i][4] := IntToStr(Trunc((360 - Abs(U[i] - dat[i]) - StrToFloat(R[i][3])) * 60));
    end;
  end;

  if ComboBox1.ItemIndex = 0 then q := 1
  else if ComboBox1.ItemIndex = 1 then q := -1
  else q := 0;

  if Abs(q * U[4] - dat[4]) < (360 - Abs(q * U[4] - dat[4])) then
  begin
    R[4][3] := IntToStr(Trunc(Abs(q * U[4] - dat[4])));
    R[4][4] := IntToStr(Round((Abs(q * U[4] - dat[4]) - StrToFloat(R[4][3])) * 60));
  end
  else
  begin
    R[4][3] := IntToStr(Trunc(360 - Abs(q * U[4] - dat[4])));
    R[4][4] := IntToStr(Round((360 - Abs(q * U[4] - dat[4]) - StrToFloat(R[4][3])) * 60));
  end;

  // Форматирование вывода (пробелы)
  for i := 1 to 4 do
  begin
    for j := 1 to (6 - Length(TrimLeft(R[i][3]))) do R[i][3] := '  ' + R[i][3];
    for j := 1 to (2 - Length(TrimLeft(R[i][4]))) do R[i][4] := '  ' + R[i][4];
    for j := 1 to (3 - Length(TrimLeft(R[i][1]))) do R[i][1] := '  ' + R[i][1];
    for j := 1 to (2 - Length(TrimLeft(R[i][2]))) do R[i][2] := '  ' + R[i][2];
  end;

  // Оценка результата
  for i := 1 to 3 do
  begin
    if (StrToFloat(R[i][3]) + StrToFloat(R[i][4]) / 60) <= 1.2 then
      R[i][5] := '✓'
    else
      R[i][5] := '✕';
    for j := 1 to 12 do R[i][5] := ' ' + R[i][5];
  end;

  if (StrToFloat(R[4][3]) + StrToFloat(R[4][4]) / 60) <= 0.02 then
    R[4][5] := '✓'
  else
    R[4][5] := '✕';
  for j := 1 to 12 do R[4][5] := ' ' + R[4][5];

  // Вывод сообщения
  ShowMessage(
    'Величина                                    Значение    Ошибка    Результат' + #13#10 +
    'Дирекционный угол                   ' + R[1][1] + '° ' + R[1][2] + #39 + R[1][3] + '° ' + R[1][4] + #39 + R[1][5] + #13#10 +
