procedure TFormcorners100k.FormMouseWheelDown(Sender: TObject; Shift: TShiftState;
  MousePos: TPoint; var Handled: Boolean);
begin
  if Tr or (whatDraw = 'L') or FixL then
  begin
    if CtrlDown then
      spin := spin - 0.4
    else
      spin := spin - 5;

    if spin < 0 then
      spin := spin + 360;

    LPaint;
    Handled := True;
  end;
end;

procedure TFormcorners100k.FormMouseWheelUp(Sender: TObject; Shift: TShiftState;
  MousePos: TPoint; var Handled: Boolean);
begin
  if Tr or (whatDraw = 'L') or FixL then
  begin
    if CtrlDown then
      spin := spin + 0.4
    else
      spin := spin + 5;

    if spin >= 360 then
      spin := spin - 360;

    LPaint;
    Handled := True;
  end;
end;

